<Window x:Class="GhostBrowser.IncognitoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:GhostBrowser"
        xmlns:vm="clr-namespace:GhostBrowser.ViewModels"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="GhostBrowser — Incognito"
        Height="720" Width="1280"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        MinWidth="860" MinHeight="520"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        SizeChanged="Window_SizeChanged">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="8" GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Storyboard x:Key="WindowFadeIn">
            <DoubleAnimation Storyboard.TargetName="WindowRoot"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <PowerEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <DataTemplate DataType="{x:Type vm:TabViewModel}">
            <ContentControl Content="{Binding WebView}" />
        </DataTemplate>

        <!-- Стиль TabControl -->
        <Style x:Key="BrowserTabControl" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <!-- Горизонтальная панель вкладок: слева направо -->
                        <StackPanel IsItemsHost="True"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль TabItem -->
        <Style x:Key="BrowserTabItemStyle" TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="0,0,2,0"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8,8,0,0"
                                Padding="{TemplateBinding Padding}"
                                MinWidth="120" MaxWidth="200">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{TemplateBinding Header}"
                                           Foreground="{TemplateBinding Foreground}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           FontSize="{TemplateBinding FontSize}"
                                           FontWeight="{TemplateBinding FontWeight}"/>
                                <Button Grid.Column="1" Content="✕"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="{TemplateBinding Foreground}"
                                        FontSize="10" Cursor="Hand"
                                        Width="18" Height="18"
                                        HorizontalAlignment="Right"
                                        Click="CloseTabBtn_Click">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Bg" Background="Transparent" CornerRadius="4">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource BgOverlayBrush}"/>
                                                                <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBg" Property="Background" Value="{StaticResource BgSurfaceBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль кнопки -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.FontSize="16"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource BgSurfaceBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.92" ScaleY="0.92" CenterX="18" CenterY="18"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль URL Bar -->
        <Style x:Key="UrlBar" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BgSurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18,11"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="22">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="14" ShadowDepth="0" Opacity="0.35" Color="{StaticResource Accent}"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Outer glow -->
    <Border x:Name="WindowRoot" Opacity="0"
            SnapsToDevicePixels="True"
            UseLayoutRounding="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="0" Opacity="0.45" Color="#000000"/>
        </Border.Effect>

        <Border Background="{StaticResource BgDeepestBrush}"
                CornerRadius="14"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="1"
                SnapsToDevicePixels="True"
                UseLayoutRounding="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.25" Color="#000000"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="3"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="28"/>
                </Grid.RowDefinitions>

                <!-- ════════════ TITLE BAR ════════════ -->
                <Border Grid.Row="0" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="{StaticResource BgDeepest}" Offset="0"/>
                            <GradientStop Color="#06090f" Offset="0.5"/>
                            <GradientStop Color="{StaticResource BgDeep}" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Logo -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="16,0,0,0">
                            <Border CornerRadius="8" Width="28" Height="28" VerticalAlignment="Center">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#7c5cfc" Offset="0"/>
                                        <GradientStop Color="#a855f7" Offset="0.5"/>
                                        <GradientStop Color="#d946ef" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="🕶️" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Incognito" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" Margin="10,0,0,0"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                        </StackPanel>

                        <!-- Incognito Indicator -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                            <Border Width="8" Height="8" CornerRadius="4"
                                    VerticalAlignment="Center" Margin="0,0,8,0">
                                <Border.Background>
                                    <SolidColorBrush Color="#a855f7"/>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="6" ShadowDepth="0" Opacity="0.3" Color="#a855f7"/>
                                </Border.Effect>
                            </Border>
                            <TextBlock Text="INCOGNITO" FontSize="11" FontWeight="Medium"
                                       Foreground="#a855f7"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                        </StackPanel>

                        <!-- Window Controls -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Button x:Name="BtnMinimize" Width="46" Height="34"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    FontSize="12" Cursor="Hand" Click="BtnMinimize_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bg" Background="Transparent" CornerRadius="6">
                                                        <TextBlock Text="─" Foreground="{TemplateBinding Foreground}"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                   FontSize="13" FontFamily="Consolas"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource BgSurfaceBrush}"/>
                                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button x:Name="BtnMaximize" Width="46" Height="34"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    FontSize="11" Cursor="Hand" Click="BtnMaximize_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bg" Background="Transparent" CornerRadius="6">
                                                        <TextBlock Text="□" Foreground="{TemplateBinding Foreground}"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                   FontSize="12" FontFamily="Consolas"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource BgSurfaceBrush}"/>
                                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button x:Name="BtnClose" Width="46" Height="34"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    FontSize="10" Cursor="Hand" Click="BtnClose_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bg" Background="Transparent" CornerRadius="6">
                                                        <TextBlock Text="✕" Foreground="{TemplateBinding Foreground}"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                   FontSize="11" FontFamily="Consolas"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource DangerBrush}"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ════════════ TAB BAR ════════════ -->
                <Border Grid.Row="1" Padding="12,8,12,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="{StaticResource BgDeepest}" Offset="0"/>
                            <GradientStop Color="{StaticResource BgDeep}" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TabControl x:Name="TabsControl"
                                    Grid.Column="0"
                                    ItemsSource="{Binding Tabs}"
                                    SelectedItem="{Binding SelectedTab}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Style="{StaticResource BrowserTabControl}">
                            <TabControl.ItemContainerStyle>
                                <Style TargetType="TabItem" BasedOn="{StaticResource BrowserTabItemStyle}">
                                    <Setter Property="Header" Value="{Binding Title}"/>
                                </Style>
                            </TabControl.ItemContainerStyle>
                        </TabControl>

                        <Button Grid.Column="1" Content="+" Width="32" Height="30"
                                FontSize="18" FontWeight="Light"
                                Cursor="Hand" Margin="6,0,0,2"
                                Command="{Binding AddTabCommand}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bg" Property="Background" Value="{StaticResource BgSurfaceBrush}"/>
                                                        <Setter Property="Foreground" Value="#a855f7"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <!-- ════════════ NAVIGATION BAR ════════════ -->
                <Border Grid.Row="2" Padding="14,8"
                        BorderBrush="{StaticResource BorderSubtleBrush}"
                        BorderThickness="0,0,0,1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="{StaticResource BgDeep}" Offset="0"/>
                            <GradientStop Color="{StaticResource BgPrimary}" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Content="←" Style="{StaticResource IconBtn}"
                                Margin="0,0,2,0" Command="{Binding GoBackCommand}"
                                ToolTip="Назад (Alt+←)"/>

                        <Button Grid.Column="1" Content="→" Style="{StaticResource IconBtn}"
                                Margin="0,0,2,0" Command="{Binding GoForwardCommand}"
                                ToolTip="Вперёд (Alt+→)"/>

                        <Button Grid.Column="2" Content="⟳" Style="{StaticResource IconBtn}"
                                Margin="0,0,2,0" Command="{Binding RefreshCommand}"
                                ToolTip="Обновить (Ctrl+R)"/>

                        <Button Grid.Column="3" Content="⌂" Style="{StaticResource IconBtn}"
                                Margin="0,0,10,0" Command="{Binding GoHomeCommand}"
                                ToolTip="Домой"/>

                        <!-- URL Bar -->
                        <Grid Grid.Column="4">
                            <TextBox x:Name="UrlBox" Style="{StaticResource UrlBar}"
                                     Text="{Binding UrlInput, UpdateSourceTrigger=PropertyChanged}"
                                     KeyDown="UrlBox_KeyDown" GotFocus="UrlBox_GotFocus"/>
                            <TextBlock x:Name="UrlPlaceholder"
                                       Text="  Введите URL или поисковый запрос..."
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       FontSize="13.5" FontStyle="Italic"
                                       VerticalAlignment="Center" IsHitTestVisible="False"
                                       Opacity="0.7"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                        </Grid>

                        <!-- Search Engine -->
                        <Button Grid.Column="5" Margin="6,0,0,0"
                                Command="{Binding CycleSearchEngineCommand}"
                                ToolTip="Поисковая система">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource IconBtn}">
                                    <Setter Property="Content" Value="{Binding SearchEngineIcon}"/>
                                    <Setter Property="FontSize" Value="14"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Stealth -->
                        <Button Grid.Column="6" Content="👻" Style="{StaticResource IconBtn}"
                                Margin="6,0,0,0" Command="{Binding ToggleStealthCommand}"
                                FontSize="15"
                                ToolTip="Скрыть от OBS/Discord (Ctrl+Shift+H)"/>
                    </Grid>
                </Border>

                <!-- ════════════ PROGRESS BAR ════════════ -->
                <Border Grid.Row="3">
                    <ProgressBar x:Name="ProgressBar" Height="3"
                                 Background="Transparent" BorderThickness="0"
                                 Maximum="100" Value="0">
                        <ProgressBar.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#7c5cfc" Offset="0"/>
                                <GradientStop Color="#a855f7" Offset="0.5"/>
                                <GradientStop Color="#d946ef" Offset="1"/>
                            </LinearGradientBrush>
                        </ProgressBar.Foreground>
                    </ProgressBar>
                </Border>

                <!-- ════════════ CONTENT AREA ════════════ -->
                <ContentControl Grid.Row="4"
                                Content="{Binding DisplayedContent}"/>

                <!-- ════════════ STATUS BAR ════════════ -->
                <Border Grid.Row="5" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,1,0,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="{StaticResource BgDeepest}" Offset="0"/>
                            <GradientStop Color="{StaticResource BgDeep}" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="StatusTextBlock"
                                   Text="{Binding StatusText}"
                                   FontSize="10.5"
                                   Foreground="{StaticResource TextTertiaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"
                                   FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="🕶️" FontSize="10"
                                       Foreground="#a855f7"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding ClockTime}"
                                       FontSize="10.5"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,0"
                                       FontFamily="Consolas, 'Cascadia Code', monospace"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Border>
</Window>
