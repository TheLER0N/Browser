### Dispose с отпиской
```csharp
// ✅ ПРАВИЛЬНО:
public void Dispose()
{
    if (WebView != null)
    {
        // 1. Сначала отписка
        WebView.NavigationStarting -= OnNavigationStarting;
        WebView.NavigationCompleted -= OnNavigationCompleted;
        // 2. Потом Dispose
        WebView.Dispose();
        _webView = null;
    }
}
```

