<UserControl x:Class="GhostBrowser.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded"
             Background="{StaticResource BgDeepestBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ LEFT SIDEBAR ═══ -->
        <Border Grid.Column="0"
                Background="{StaticResource BgDeepBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,0,1,0">
            <StackPanel Margin="0,20,0,0">
                <!-- Back Button -->
                <Button x:Name="BackBtn"
                        Margin="14,8" Padding="16,10"
                        Style="{StaticResource GlassBtn}"
                        Click="BackBtn_Click">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="←" Margin="0,0,8,0" FontSize="13"/>
                            <TextBlock Text="Назад" FontSize="13" FontWeight="Medium"/>
                        </StackPanel>
                    </Button.Content>
                </Button>

                <!-- Section Title -->
                <TextBlock Text="Меню" FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="18,14,18,16"
                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

                <!-- Nav Items -->
                <Button x:Name="NavDnsBtn" Content="🌐  DNS-сервер"
                        Style="{StaticResource MenuNavItemBtn}" Margin="8,2"
                        Click="NavDns_Click" FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                <Button x:Name="NavGeneralBtn" Content="⚙️  Общие"
                        Style="{StaticResource MenuNavItemBtn}" Margin="8,2"
                        Click="NavGeneral_Click" FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                <Button x:Name="NavAppearanceBtn" Content="🎨  Внешний вид"
                        Style="{StaticResource MenuNavItemBtn}" Margin="8,2"
                        Click="NavAppearance_Click" FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                <Button x:Name="NavPerformanceBtn" Content="⚡  Производительность"
                        Style="{StaticResource MenuNavItemBtn}" Margin="8,2"
                        Click="NavPerformance_Click" FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                <Button x:Name="NavPrivacyBtn" Content="🛡️  Приватность"
                        Style="{StaticResource MenuNavItemBtn}" Margin="8,2"
                        Click="NavPrivacy_Click" FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                <Button x:Name="NavAdBlockBtn" Content="🚫  AdBlock"
                        Style="{StaticResource MenuNavItemBtn}" Margin="8,2"
                        Click="NavAdBlock_Click" FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                <Button x:Name="NavNetworkBtn" Content="🌐  Сеть"
                        Style="{StaticResource MenuNavItemBtn}" Margin="8,2"
                        Click="NavNetwork_Click" FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                <Button x:Name="NavStartupBtn" Content="🚀  При запуске"
                        Style="{StaticResource MenuNavItemBtn}" Margin="8,2"
                        Click="NavStartup_Click" FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                <Button x:Name="NavSearchBtn" Content="🔍  Поиск"
                        Style="{StaticResource MenuNavItemBtn}" Margin="8,2"
                        Click="NavSearch_Click" FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                <Button x:Name="NavNotificationsBtn" Content="🔔  Уведомления"
                        Style="{StaticResource MenuNavItemBtn}" Margin="8,2"
                        Click="NavNotifications_Click" FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                <Button x:Name="NavExperimentalBtn" Content="🧪  Экспериментальные"
                        Style="{StaticResource MenuNavItemBtn}" Margin="8,2"
                        Click="NavExperimental_Click" FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                <Button x:Name="NavScreenshotBtn" Content="📸  Скриншоты"
                        Style="{StaticResource MenuNavItemBtn}" Margin="8,2"
                        Click="NavScreenshot_Click" FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                <Button x:Name="NavAutoFillBtn" Content="✍️  Автозаполнение"
                        Style="{StaticResource MenuNavItemBtn}" Margin="8,2"
                        Click="NavAutoFill_Click" FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                <Button x:Name="NavProfilesBtn" Content="👤  Профили"
                        Style="{StaticResource MenuNavItemBtn}" Margin="8,2"
                        Click="NavProfiles_Click" FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                <Button x:Name="NavHistoryBtn" Content="📜  История"
                        Style="{StaticResource MenuNavItemBtn}" Margin="8,2"
                        Click="NavHistory_Click" FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                <Button x:Name="NavBookmarksBtn" Content="⭐  Закладки"
                        Style="{StaticResource MenuNavItemBtn}" Margin="8,2"
                        Click="NavBookmarks_Click" FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                <Button x:Name="NavSyncBtn" Content="🔄  Синхронизация"
                        Style="{StaticResource MenuNavItemBtn}" Margin="8,2"
                        Click="NavSync_Click" FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                <Button x:Name="NavDownloadsBtn" Content="📥  Загрузки"
                        Style="{StaticResource MenuNavItemBtn}" Margin="8,2"
                        Click="NavDownloads_Click" FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                <Button x:Name="NavAboutBtn" Content="ℹ️  О программе"
                        Style="{StaticResource MenuNavItemBtn}" Margin="8,2"
                        Click="NavAbout_Click" FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
            </StackPanel>
        </Border>

        <!-- ═══ RIGHT CONTENT ═══ -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="36,28">
            <StackPanel MaxWidth="620">

                <!-- ─── DNS Section ─── -->
                <StackPanel x:Name="DnsSection" Visibility="Visible">
                    <TextBlock Text="DNS-сервер" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <TextBlock Text="Выберите DNS-сервер для подключения"
                               Foreground="{StaticResource TextTertiaryBrush}" FontSize="12.5"
                               Margin="0,0,0,28"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

                    <!-- Toggle Card -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Использовать кастомный DNS"
                                       FontSize="14" FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            <ToggleButton x:Name="UseCustomDnsToggle"
                                          IsChecked="{Binding SettingsService.UseCustomDns}"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"/>
                        </Grid>
                    </Border>

                    <TextBlock Text="Пресеты" FontSize="11.5" FontWeight="SemiBold"
                               Foreground="{StaticResource TextTertiaryBrush}"
                               Margin="0,0,0,8"/>

                    <ComboBox x:Name="DnsPresetCombo"
                              ItemsSource="{Binding SettingsService.DnsPresetsSource}"
                              SelectedValue="{Binding SettingsService.SelectedDnsPreset, Mode=TwoWay}"
                              SelectedValuePath="Name"
                              Style="{StaticResource SettingsCombo}"
                              Margin="0,0,0,16" MaxDropDownHeight="320">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="4,6">
                                    <TextBlock Text="{Binding Name}" FontWeight="Medium"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="12.5"
                                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                    <TextBlock Text="  " Foreground="{StaticResource TextTertiaryBrush}" FontSize="11"/>
                                    <TextBlock Text="{Binding Primary}"
                                               Foreground="{StaticResource AccentSoftBrush}"
                                               FontFamily="Consolas, 'Cascadia Code', monospace"
                                               FontSize="11.5" FontWeight="Medium"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Tip Card -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="12" Padding="14" Margin="0,0,0,18">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💡" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Для обхода блокировок: Cloudflare, UncensoredDNS, Control D"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" LineHeight="18"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Адрес DNS-сервера" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="DnsInput"
                                 Text="{Binding SettingsService.CustomDns, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SettingsTextBox}"
                                 FontFamily="Consolas, 'Cascadia Code', monospace"
                                 FontSize="13"/>
                        <Button Grid.Column="1" Content="🔍  Тест"
                                Style="{StaticResource GlassBtn}"
                                Margin="10,0,0,0" Padding="16,10"
                                Click="TestDnsBtn_Click"
                                FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    </Grid>
                </StackPanel>

                <!-- ─── General Section ─── -->
                <StackPanel x:Name="GeneralSection" Visibility="Collapsed">
                    <TextBlock Text="Общие настройки" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <TextBlock Text="Основные параметры браузера"
                               Foreground="{StaticResource TextTertiaryBrush}" FontSize="12.5"
                               Margin="0,0,0,28"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Тёмная тема" FontSize="14" FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            <ToggleButton x:Name="DarkThemeToggle"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"/>
                        </Grid>
                    </Border>

                    <TextBlock Text="Размер шрифта" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="FontSizeSlider"
                                Value="{Binding SettingsService.FontSize}"
                                Minimum="10" Maximum="24" TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Style="{StaticResource SettingsSlider}"/>
                        <TextBlock Grid.Column="1" x:Name="FontSizeText"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12" FontFamily="Consolas, monospace"
                                   VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Grid>

                    <TextBlock Text="Домашняя страница" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <TextBox x:Name="HomePageInput"
                             Text="{Binding SettingsService.HomePage, UpdateSourceTrigger=LostFocus}"
                             Style="{StaticResource SettingsTextBox}"
                             Margin="0,0,0,0"/>
                </StackPanel>

                <!-- ─── Appearance Section ─── -->
                <StackPanel x:Name="AppearanceSection" Visibility="Collapsed">
                    <TextBlock Text="Внешний вид" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <TextBlock Text="Настройки внешнего вида интерфейса"
                               Foreground="{StaticResource TextTertiaryBrush}" FontSize="12.5"
                               Margin="0,0,0,28"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

                    <!-- Тема оформления -->
                    <TextBlock Text="Тема оформления" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <ComboBox x:Name="ThemeCombo" Margin="0,0,0,18"
                              Style="{StaticResource SettingsCombo}">
                        <ComboBoxItem Content="🌙  Тёмная" Tag="dark"/>
                        <ComboBoxItem Content="☀️  Светлая" Tag="light"/>
                        <ComboBoxItem Content="💻  Системная" Tag="system"/>
                    </ComboBox>

                    <!-- Акцентный цвет -->
                    <TextBlock Text="Акцентный цвет" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                        <RadioButton x:Name="AccentBlue" Content="🔵" Margin="0,0,12,0" GroupName="AccentColor" Checked="AccentColor_Checked" Tag="blue" FontSize="16"/>
                        <RadioButton x:Name="AccentPurple" Content="🟣" Margin="0,0,12,0" GroupName="AccentColor" Checked="AccentColor_Checked" Tag="purple" FontSize="16"/>
                        <RadioButton x:Name="AccentGreen" Content="🟢" Margin="0,0,12,0" GroupName="AccentColor" Checked="AccentColor_Checked" Tag="green" FontSize="16"/>
                        <RadioButton x:Name="AccentRed" Content="🔴" Margin="0,0,12,0" GroupName="AccentColor" Checked="AccentColor_Checked" Tag="red" FontSize="16"/>
                        <RadioButton x:Name="AccentCustom" Content="✏️" GroupName="AccentColor" Checked="AccentColor_Checked" Tag="custom" FontSize="16"/>
                        <TextBox x:Name="CustomAccentColorInput" Width="90" Margin="12,0,0,0"
                                 Style="{StaticResource SettingsTextBox}" FontSize="11"
                                 FontFamily="Consolas, monospace"
                                 LostFocus="CustomAccentColor_LostFocus"/>
                    </StackPanel>

                    <!-- Масштаб страницы -->
                    <TextBlock Text="Масштаб страницы по умолчанию" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="ZoomSlider"
                                Value="{Binding SettingsService.DefaultZoomLevel}"
                                Minimum="0.5" Maximum="2.0" TickFrequency="0.1"
                                IsSnapToTickEnabled="True" Style="{StaticResource SettingsSlider}"/>
                        <TextBlock Grid.Column="1" x:Name="ZoomText"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12" FontFamily="Consolas, monospace"
                                   VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Grid>

                    <!-- Показать панель закладок -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Панель закладок" FontSize="14" FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            <ToggleButton x:Name="ShowBookmarksBarToggle"
                                          IsChecked="{Binding SettingsService.ShowBookmarksBar}"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"/>
                        </Grid>
                    </Border>

                    <!-- Показать статус-бар -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Статус-бар" FontSize="14" FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            <ToggleButton x:Name="ShowStatusBarToggle"
                                          IsChecked="{Binding SettingsService.ShowStatusBar}"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"/>
                        </Grid>
                    </Border>

                    <!-- Скруглённые вкладки -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Скруглённые вкладки" FontSize="14" FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            <ToggleButton x:Name="RoundedTabsToggle"
                                          IsChecked="{Binding SettingsService.RoundedTabs}"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- ─── Performance Section ─── -->
                <StackPanel x:Name="PerformanceSection" Visibility="Collapsed">
                    <TextBlock Text="Производительность" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <TextBlock Text="Настройки производительности и ресурсов"
                               Foreground="{StaticResource TextTertiaryBrush}" FontSize="12.5"
                               Margin="0,0,0,28"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

                    <!-- Аппаратное ускорение -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Аппаратное ускорение" FontSize="14" FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                <TextBlock Text="Использует GPU для рендеринга страниц" FontSize="11"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           Margin="0,2,0,0"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            </StackPanel>
                            <ToggleButton x:Name="HardwareAccelerationToggle"
                                          IsChecked="{Binding SettingsService.HardwareAcceleration}"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"/>
                        </Grid>
                    </Border>

                    <!-- Автоочистка кэша -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Автоочистка кэша при закрытии" FontSize="14" FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                <TextBlock Text="Освобождает место на диске" FontSize="11"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           Margin="0,2,0,0"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            </StackPanel>
                            <ToggleButton x:Name="AutoClearCacheToggle"
                                          IsChecked="{Binding SettingsService.AutoClearCacheOnExit}"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"/>
                        </Grid>
                    </Border>

                    <!-- Предзагрузка страниц -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Предзагрузка страниц" FontSize="14" FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                <TextBlock Text="Ускоряет переход по ссылкам" FontSize="11"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           Margin="0,2,0,0"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            </StackPanel>
                            <ToggleButton x:Name="PagePrefetchToggle"
                                          IsChecked="{Binding SettingsService.PagePrefetch}"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"/>
                        </Grid>
                    </Border>

                    <!-- Потоки загрузок -->
                    <TextBlock Text="Потоки загрузок" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,18,0,8"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="DownloadThreadsSlider"
                                Value="{Binding SettingsService.DownloadThreads}"
                                Minimum="1" Maximum="8" TickFrequency="1"
                                IsSnapToTickEnabled="True" Style="{StaticResource SettingsSlider}"/>
                        <TextBlock Grid.Column="1" x:Name="DownloadThreadsText"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12" FontFamily="Consolas, monospace"
                                   VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Grid>

                    <!-- Лимит RAM -->
                    <TextBlock Text="Лимит оперативной памяти (МБ, 0 = без ограничений)" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <TextBox x:Name="MemoryLimitInput"
                             Style="{StaticResource SettingsTextBox}"
                             FontFamily="Consolas, monospace" FontSize="12"
                             TextChanged="MemoryLimitInput_TextChanged"/>
                </StackPanel>

                <!-- ─── Privacy Section ─── -->
                <StackPanel x:Name="PrivacySection" Visibility="Collapsed">
                    <TextBlock Text="Приватность" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <TextBlock Text="Настройки безопасности"
                               Foreground="{StaticResource TextTertiaryBrush}" FontSize="12.5"
                               Margin="0,0,0,28"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Блокировка трекеров" FontSize="14" FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            <ToggleButton x:Name="BlockTrackersToggle"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"/>
                        </Grid>
                    </Border>

                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Блокировка cookies третьих сторон" FontSize="14"
                                       FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            <ToggleButton x:Name="BlockCookiesToggle"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- ─── AdBlock Section ─── -->
                <StackPanel x:Name="AdBlockSection" Visibility="Collapsed">
                    <TextBlock Text="AdBlock" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <TextBlock Text="Блокировка рекламы и трекеров"
                               Foreground="{StaticResource TextTertiaryBrush}" FontSize="12.5"
                               Margin="0,0,0,28"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

                    <!-- Status banner -->
                    <Border x:Name="AdBlockStatusBanner"
                            Background="#1a2e1a" BorderBrush="{StaticResource SuccessBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,18">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✅" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="AdBlock активен" FontSize="14" FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                <TextBlock x:Name="AdBlockStatusText" Text="Заблокировано запросов: 0" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,2,0,0"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Toggle -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Включить AdBlock" FontSize="14" FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                <TextBlock Text="Блокирует рекламу, трекеры и аналитику" FontSize="11"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           Margin="0,2,0,0"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            </StackPanel>
                            <ToggleButton x:Name="AdBlockEnabledToggle"
                                          IsChecked="{Binding AdBlockService.IsEnabled}"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"/>
                        </Grid>
                    </Border>

                    <!-- Filter lists -->
                    <TextBlock Text="Списки фильтров" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,16">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text=" KING Basic Filter" FontSize="13" FontWeight="Medium"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                    <TextBlock Text="Встроенный набор правил (реклама + трекеры)" FontSize="11"
                                               Foreground="{StaticResource TextTertiaryBrush}"
                                               Margin="0,2,0,0"
                                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" x:Name="BasicFilterBlocked"
                                           Text="0" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"
                                           FontFamily="Consolas, monospace"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Reset counter -->
                    <Button x:Name="ResetAdBlockCounterBtn" Content="🔄  Сбросить счётчик"
                            Style="{StaticResource GlassBtn}"
                            Padding="16,10" HorizontalAlignment="Left"
                            Click="ResetAdBlockCounter_Click"
                            FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                </StackPanel>

                <!-- ─── Network Section ─── -->
                <StackPanel x:Name="NetworkSection" Visibility="Collapsed">
                    <TextBlock Text="Сеть" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <TextBlock Text="Настройки сети, DNS и прокси"
                               Foreground="{StaticResource TextTertiaryBrush}" FontSize="12.5"
                               Margin="0,0,0,28"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

                    <!-- ═══ Обход блокировок ═══ -->
                    <Border Background="#1a1a2e" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Text="🔓 Обход блокировок" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            <TextBlock Text="Выберите способ обхода блокировок сайтов" FontSize="11"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       Margin="0,2,0,0"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                        </StackPanel>
                    </Border>

                    <!-- Профиль: Без обхода -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="🔒  Без обхода" FontSize="14" FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                <TextBlock Text="Стандартный DNS провайдера" FontSize="11"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           Margin="0,2,0,0"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            </StackPanel>
                            <RadioButton x:Name="BypassNone" Grid.Column="1"
                                         GroupName="BypassMode" Checked="BypassMode_Checked" Tag="none"
                                         VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Профиль: DoH Cloudflare -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="☁️  DoH Cloudflare" FontSize="14" FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                <TextBlock Text="DNS over HTTPS через 1.1.1.1 — обход DNS-блокировок" FontSize="11"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           Margin="0,2,0,0"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            </StackPanel>
                            <RadioButton x:Name="BypassDoHCloudflare" Grid.Column="1"
                                         GroupName="BypassMode" Checked="BypassMode_Checked" Tag="doh_cloudflare"
                                         VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Профиль: DoH Google -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="🔵  DoH Google" FontSize="14" FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                <TextBlock Text="DNS over HTTPS через 8.8.8.8 — обход DNS-блокировок" FontSize="11"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           Margin="0,2,0,0"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            </StackPanel>
                            <RadioButton x:Name="BypassDoHGoogle" Grid.Column="1"
                                         GroupName="BypassMode" Checked="BypassMode_Checked" Tag="doh_google"
                                         VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Профиль: Прокси -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="🌐  Прокси" FontSize="14" FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                <TextBlock Text="Полный обход через SOCKS/HTTP прокси" FontSize="11"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           Margin="0,2,0,0"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            </StackPanel>
                            <RadioButton x:Name="BypassProxy" Grid.Column="1"
                                         GroupName="BypassMode" Checked="BypassMode_Checked" Tag="proxy"
                                         VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Настройки прокси (показываются только если выбран прокси) -->
                    <StackPanel x:Name="ProxySettingsPanel" Visibility="Collapsed" Margin="0,0,0,18">
                        <TextBlock Text="Настройки прокси-сервера" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"
                                   FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                        <ComboBox x:Name="ProxyTypeCombo" Margin="0,0,0,8"
                                  Style="{StaticResource SettingsCombo}">
                            <ComboBoxItem Content="SOCKS5" Tag="socks5"/>
                            <ComboBoxItem Content="HTTP" Tag="http"/>
                        </ComboBox>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="ProxyServerInput"
                                     Style="{StaticResource SettingsTextBox}"
                                     FontFamily="Consolas, monospace" FontSize="12"/>
                            <TextBox Grid.Column="1" x:Name="ProxyServerPortInput"
                                     Style="{StaticResource SettingsTextBox}"
                                     FontFamily="Consolas, monospace" FontSize="12"
                                     Margin="8,0,0,0"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="ProxyUsernameInput"
                                     Style="{StaticResource SettingsTextBox}"
                                     FontFamily="Consolas, monospace" FontSize="12"
                                     Margin="0,0,4,0"/>
                            <PasswordBox x:Name="ProxyPasswordInput"
                                         Grid.Column="1"
                                         FontFamily="Consolas, monospace" FontSize="12"
                                         Margin="4,0,0,0"
                                         BorderBrush="{StaticResource BorderSubtleBrush}"
                                         BorderThickness="1"
                                         Background="{StaticResource BgElevatedBrush}"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         Padding="8,6"/>
                        </Grid>
                    </StackPanel>

                    <!-- Обычные DNS настройки (скрываются если DoH включён) -->
                    <StackPanel x:Name="ClassicDnsPanel" Margin="0,0,0,18">
                        <TextBlock Text="Обычный DNS-сервер" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"
                                   FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                        <ComboBox x:Name="DnsPresetComboNetwork" Margin="0,0,0,8"
                                  Style="{StaticResource SettingsCombo}">
                            <ComboBoxItem Content="Google (8.8.8.8)" Tag="8.8.8.8"/>
                            <ComboBoxItem Content="Cloudflare (1.1.1.1)" Tag="1.1.1.1"/>
                            <ComboBoxItem Content="Quad9 (9.9.9.9)" Tag="9.9.9.9"/>
                            <ComboBoxItem Content="Yandex (77.88.8.8)" Tag="77.88.8.8"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Статус подключения -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Text="Статус обхода" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            <TextBlock x:Name="BypassStatusText" FontSize="12"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       TextWrapping="Wrap"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ─── Startup Section ─── -->
                <StackPanel x:Name="StartupSection" Visibility="Collapsed">
                    <TextBlock Text="При запуске" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <TextBlock Text="Настройки запуска и восстановления сессии"
                               Foreground="{StaticResource TextTertiaryBrush}" FontSize="12.5"
                               Margin="0,0,0,28"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

                    <!-- Режим запуска -->
                    <TextBlock Text="Открывать при запуске" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <StackPanel Margin="0,0,0,18">
                        <RadioButton x:Name="StartupNewTab" Content="📄  Новую вкладку"
                                     Margin="0,4" GroupName="StartupMode" Checked="StartupMode_Checked" Tag="newtab"
                                     FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                        <RadioButton x:Name="StartupHomepage" Content="🏠  Домашнюю страницу"
                                     Margin="0,4" GroupName="StartupMode" Checked="StartupMode_Checked" Tag="homepage"
                                     FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                        <RadioButton x:Name="StartupLastSession" Content="🔄  Предыдущие вкладки"
                                     Margin="0,4" GroupName="StartupMode" Checked="StartupMode_Checked" Tag="lastsession"
                                     FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                        <RadioButton x:Name="StartupCustomUrls" Content="✏️  Набор URL"
                                     Margin="0,4" GroupName="StartupMode" Checked="StartupMode_Checked" Tag="customurls"
                                     FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    </StackPanel>

                    <!-- Восстановление после краха -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Восстановление после краха" FontSize="14" FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                <TextBlock Text="Автоматически восстанавливать вкладки" FontSize="11"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           Margin="0,2,0,0"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            </StackPanel>
                            <ToggleButton x:Name="RestoreSessionOnCrashToggle"
                                          IsChecked="{Binding SettingsService.RestoreSessionOnCrash}"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- ─── Search Section ─── -->
                <StackPanel x:Name="SearchSection" Visibility="Collapsed">
                    <TextBlock Text="Поиск" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <TextBlock Text="Настройки поисковой системы"
                               Foreground="{StaticResource TextTertiaryBrush}" FontSize="12.5"
                               Margin="0,0,0,28"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

                    <!-- Поисковые подсказки -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Поисковые подсказки" FontSize="14" FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                <TextBlock Text="Показывать подсказки при вводе" FontSize="11"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           Margin="0,2,0,0"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            </StackPanel>
                            <ToggleButton x:Name="SearchSuggestionsToggle"
                                          IsChecked="{Binding SettingsService.SearchSuggestions}"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"/>
                        </Grid>
                    </Border>

                    <!-- Открытие в новой вкладке -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Открывать в новой вкладке" FontSize="14" FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                <TextBlock Text="Результаты поиска в новой вкладке" FontSize="11"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           Margin="0,2,0,0"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            </StackPanel>
                            <ToggleButton x:Name="OpenSearchInNewTabToggle"
                                          IsChecked="{Binding SettingsService.OpenSearchInNewTab}"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- ─── Notifications Section ─── -->
                <StackPanel x:Name="NotificationsSection" Visibility="Collapsed">
                    <TextBlock Text="Уведомления" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <TextBlock Text="Настройки звуков и уведомлений"
                               Foreground="{StaticResource TextTertiaryBrush}" FontSize="12.5"
                               Margin="0,0,0,28"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

                    <!-- Звук загрузки -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Звук завершения загрузки" FontSize="14" FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                <TextBlock Text="Воспроизводить звук" FontSize="11"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           Margin="0,2,0,0"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            </StackPanel>
                            <ToggleButton x:Name="DownloadCompleteSoundToggle"
                                          IsChecked="{Binding SettingsService.DownloadCompleteSound}"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"/>
                        </Grid>
                    </Border>

                    <!-- Уведомление о загрузке -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Уведомление о загрузке" FontSize="14" FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                <TextBlock Text="Всплывающее уведомление" FontSize="11"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           Margin="0,2,0,0"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            </StackPanel>
                            <ToggleButton x:Name="DownloadCompleteNotificationToggle"
                                          IsChecked="{Binding SettingsService.DownloadCompleteNotification}"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- ─── Experimental Section ─── -->
                <StackPanel x:Name="ExperimentalSection" Visibility="Collapsed">
                    <TextBlock Text="Экспериментальные" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <TextBlock Text="Экспериментальные функции и возможности"
                               Foreground="{StaticResource TextTertiaryBrush}" FontSize="12.5"
                               Margin="0,0,0,28"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

                    <!-- Warning banner -->
                    <Border Background="#1a1a2e" BorderBrush="#f59e0b" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,18">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠️" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="Экспериментальные функции могут быть нестабильны. Используйте на свой риск."
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                        </StackPanel>
                    </Border>

                    <!-- DevTools -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="DevTools (F12)" FontSize="14" FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                <TextBlock Text="Открыть инструменты разработчика" FontSize="11"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           Margin="0,2,0,0"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            </StackPanel>
                            <ToggleButton x:Name="EnableDevToolsToggle"
                                          IsChecked="{Binding SettingsService.EnableDevTools}"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"/>
                        </Grid>
                    </Border>

                    <!-- User-Agent -->
                    <TextBlock Text="Кастомный User-Agent" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <TextBox x:Name="CustomUserAgentInput"
                             Style="{StaticResource SettingsTextBox}"
                             FontFamily="Consolas, monospace" FontSize="11"
                             Margin="0,0,0,18"
                             TextWrapping="Wrap" AcceptsReturn="False"/>

                    <!-- WebGL -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Блокировка WebGL" FontSize="14" FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                <TextBlock Text="Защита от fingerprinting" FontSize="11"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           Margin="0,2,0,0"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            </StackPanel>
                            <ToggleButton x:Name="BlockWebGLToggle"
                                          IsChecked="{Binding SettingsService.BlockWebGL}"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"/>
                        </Grid>
                    </Border>

                    <!-- Canvas -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Блокировка Canvas API" FontSize="14" FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                <TextBlock Text="Защита от fingerprinting" FontSize="11"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           Margin="0,2,0,0"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            </StackPanel>
                            <ToggleButton x:Name="BlockCanvasToggle"
                                          IsChecked="{Binding SettingsService.BlockCanvas}"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"/>
                        </Grid>
                    </Border>

                    <!-- Text-only -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Режим «только текст»" FontSize="14" FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                <TextBlock Text="Не загружать изображения" FontSize="11"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           Margin="0,2,0,0"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            </StackPanel>
                            <ToggleButton x:Name="TextOnlyModeToggle"
                                          IsChecked="{Binding SettingsService.TextOnlyMode}"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"/>
                        </Grid>
                    </Border>

                    <!-- AutoPlay -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Автовоспроизведение медиа" FontSize="14" FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                <TextBlock Text="Автозапуск видео и аудио" FontSize="11"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           Margin="0,2,0,0"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            </StackPanel>
                            <ToggleButton x:Name="AutoPlayMediaToggle"
                                          IsChecked="{Binding SettingsService.AutoPlayMedia}"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- ─── Screenshot Section ─── -->
                <StackPanel x:Name="ScreenshotSection" Visibility="Collapsed">
                    <TextBlock Text="Скриншоты" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <TextBlock Text="Настройки создания скриншотов"
                               Foreground="{StaticResource TextTertiaryBrush}" FontSize="12.5"
                               Margin="0,0,0,28"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

                    <!-- Формат -->
                    <TextBlock Text="Формат файла" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <ComboBox x:Name="ScreenshotFormatCombo" Margin="0,0,0,18"
                              Style="{StaticResource SettingsCombo}">
                        <ComboBoxItem Content="🖼️  PNG (без потерь, рекомендуется)" Tag="png"/>
                        <ComboBoxItem Content="📷  JPEG (меньше размер, сжатие)" Tag="jpeg"/>
                    </ComboBox>

                    <!-- Папка сохранения -->
                    <TextBlock Text="Папка сохранения (пусто = спрашивать)" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="ScreenshotFolderInput"
                                 Text="{Binding SettingsService.ScreenshotFolder, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SettingsTextBox}" FontSize="12"/>
                        <Button Grid.Column="1" Content="📁"
                                Style="{StaticResource GlassBtn}" Margin="10,0,0,0"
                                Padding="14,10" Click="ChooseScreenshotFolderBtn_Click"/>
                    </Grid>

                    <!-- Авто-имя -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Автоматическое имя файла" FontSize="14" FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                <TextBlock Text="screenshot_ГГГГ-ММ-ДД_ЧЧ-ММ-СС.png"
                                           FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"
                                           Margin="0,4,0,0"
                                           FontFamily="Consolas, 'Cascadia Code', monospace"/>
                            </StackPanel>
                            <ToggleButton x:Name="ScreenshotAutoNameToggle"
                                          IsChecked="{Binding SettingsService.ScreenshotAutoName}"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"/>
                        </Grid>
                    </Border>

                    <!-- Hotkey info -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="12" Padding="14" Margin="0,0,0,18">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⌨️" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Горячая клавиша: Ctrl+Shift+S"
                                       FontSize="12.5" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontFamily="Consolas, 'Cascadia Code', monospace"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ─── Profiles Section ─── -->
                <StackPanel x:Name="ProfilesSection" Visibility="Collapsed">
                    <TextBlock Text="Профили пользователей" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <TextBlock Text="Изолированные профили с собственными cookies и настройками"
                               Foreground="{StaticResource TextTertiaryBrush}" FontSize="12.5"
                               Margin="0,0,0,28"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

                    <!-- Список профилей -->
                    <ListBox x:Name="ProfilesListBox" Margin="0,0,0,16"
                             BorderThickness="0" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource BgSurfaceBrush}"
                                        BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                                        CornerRadius="10" Padding="14" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Medium"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding CreatedAt, StringFormat='Создан: {0:dd.MM.yyyy}'}"
                                                       FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Content="✏️" Tag="{Binding Id}"
                                                    Style="{StaticResource GlassBtn}" Margin="0,0,6,0"
                                                    Padding="8,6" Click="RenameProfileBtn_Click"/>
                                            <Button Content="🗑️" Tag="{Binding Id}"
                                                    Style="{StaticResource GlassBtn}" Margin="0,0,6,0"
                                                    Padding="8,6" Click="DeleteProfileBtn_Click"/>
                                            <Button Content="✅" Tag="{Binding Id}"
                                                    Style="{StaticResource GlassBtn}" Padding="8,6"
                                                    Click="ActivateProfileBtn_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Добавить профиль -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="NewProfileNameInput"
                                 Text="{Binding NewProfileName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SettingsTextBox}" FontSize="12"
                                 FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                        <Button Grid.Column="1" Content="➕ Добавить"
                                Style="{StaticResource GlassBtn}" Margin="10,0,0,0"
                                Padding="16,10" Click="AddProfileBtn_Click"/>
                    </Grid>
                </StackPanel>

                <!-- ─── AutoFill Section ─── -->
                <StackPanel x:Name="AutoFillSection" Visibility="Collapsed">
                    <TextBlock Text="Автозаполнение форм" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <TextBlock Text="Данные для автоматического заполнения веб-форм"
                               Foreground="{StaticResource TextTertiaryBrush}" FontSize="12.5"
                               Margin="0,0,0,28"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

                    <!-- Toggle -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Включить автозаполнение" FontSize="14" FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                <TextBlock Text="Автоматически заполнять формы при загрузке страницы"
                                           FontSize="11.5" Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,2,0,0"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            </StackPanel>
                            <ToggleButton x:Name="AutoFillEnabledToggle"
                                          IsChecked="{Binding AutoFillService.IsEnabled}"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"/>
                        </Grid>
                    </Border>

                    <!-- Личные данные -->
                    <TextBlock Text="Личные данные" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Имя" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,4"/>
                            <TextBox x:Name="FirstNameInput"
                                     Text="{Binding AutoFillFirstName, UpdateSourceTrigger=LostFocus}"
                                     Style="{StaticResource SettingsTextBox}" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Фамилия" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,4"/>
                            <TextBox x:Name="LastNameInput"
                                     Text="{Binding AutoFillLastName, UpdateSourceTrigger=LostFocus}"
                                     Style="{StaticResource SettingsTextBox}" FontSize="12"/>
                        </StackPanel>
                    </Grid>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Отчество" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,4"/>
                            <TextBox x:Name="MiddleNameInput"
                                     Text="{Binding AutoFillMiddleName, UpdateSourceTrigger=LostFocus}"
                                     Style="{StaticResource SettingsTextBox}" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2"/>
                    </Grid>

                    <!-- Контакты -->
                    <TextBlock Text="Контакты" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Email" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,4"/>
                            <TextBox x:Name="EmailInput"
                                     Text="{Binding AutoFillEmail, UpdateSourceTrigger=LostFocus}"
                                     Style="{StaticResource SettingsTextBox}" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Телефон" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,4"/>
                            <TextBox x:Name="PhoneInput"
                                     Text="{Binding AutoFillPhone, UpdateSourceTrigger=LostFocus}"
                                     Style="{StaticResource SettingsTextBox}" FontSize="12"/>
                        </StackPanel>
                    </Grid>

                    <!-- Адрес -->
                    <TextBlock Text="Адрес" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <TextBox x:Name="StreetInput"
                             Text="{Binding AutoFillStreet, UpdateSourceTrigger=LostFocus}"
                             Style="{StaticResource SettingsTextBox}" FontSize="12"
                             Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Город" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,4"/>
                            <TextBox x:Name="CityInput"
                                     Text="{Binding AutoFillCity, UpdateSourceTrigger=LostFocus}"
                                     Style="{StaticResource SettingsTextBox}" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Регион/Область" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,4"/>
                            <TextBox x:Name="StateInput"
                                     Text="{Binding AutoFillState, UpdateSourceTrigger=LostFocus}"
                                     Style="{StaticResource SettingsTextBox}" FontSize="12"/>
                        </StackPanel>
                    </Grid>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Почтовый индекс" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,4"/>
                            <TextBox x:Name="ZipCodeInput"
                                     Text="{Binding AutoFillZipCode, UpdateSourceTrigger=LostFocus}"
                                     Style="{StaticResource SettingsTextBox}" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Страна" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,4"/>
                            <TextBox x:Name="CountryInput"
                                     Text="{Binding AutoFillCountry, UpdateSourceTrigger=LostFocus}"
                                     Style="{StaticResource SettingsTextBox}" FontSize="12"/>
                        </StackPanel>
                    </Grid>

                    <!-- Hotkey info -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="12" Padding="14" Margin="0,0,0,18">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⌨️" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Горячая клавиша: Ctrl+Shift+F"
                                       FontSize="12.5" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontFamily="Consolas, 'Cascadia Code', monospace"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ─── History Section ─── -->
                <StackPanel x:Name="HistorySection" Visibility="Collapsed">
                    <TextBlock Text="История" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <TextBlock Text="Последние посещённые страницы"
                               Foreground="{StaticResource TextTertiaryBrush}" FontSize="12.5"
                               Margin="0,0,0,18"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <Button x:Name="ClearHistoryBtn" Content="🗑️  Очистить историю"
                            Style="{StaticResource GlassBtn}"
                            Margin="0,0,0,18" Padding="16,10"
                            HorizontalAlignment="Left"
                            Click="ClearHistoryBtn_Click"
                            FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

                    <ListView x:Name="HistoryList" MaxHeight="420"
                              Background="Transparent" BorderThickness="0">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                <Setter Property="Padding" Value="0,6"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                                <GridViewRowPresenter/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Заголовок"
                                                DisplayMemberBinding="{Binding Title}"
                                                Width="220">
                                    <GridViewColumn.HeaderContainerStyle>
                                        <Style TargetType="GridViewColumnHeader">
                                            <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="FontSize" Value="11"/>
                                        </Style>
                                    </GridViewColumn.HeaderContainerStyle>
                                </GridViewColumn>
                                <GridViewColumn Header="URL"
                                                DisplayMemberBinding="{Binding Url}"
                                                Width="260">
                                    <GridViewColumn.HeaderContainerStyle>
                                        <Style TargetType="GridViewColumnHeader">
                                            <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="FontSize" Value="11"/>
                                        </Style>
                                    </GridViewColumn.HeaderContainerStyle>
                                </GridViewColumn>
                                <GridViewColumn Header="Дата"
                                                DisplayMemberBinding="{Binding VisitedAt}"
                                                Width="140">
                                    <GridViewColumn.HeaderContainerStyle>
                                        <Style TargetType="GridViewColumnHeader">
                                            <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="FontSize" Value="11"/>
                                        </Style>
                                    </GridViewColumn.HeaderContainerStyle>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </StackPanel>

                <!-- ─── Bookmarks Section ─── -->
                <StackPanel x:Name="BookmarksSection" Visibility="Collapsed">
                    <TextBlock Text="Закладки" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <TextBlock Text="Сохранённые страницы"
                               Foreground="{StaticResource TextTertiaryBrush}" FontSize="12.5"
                               Margin="0,0,0,18"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <ListView x:Name="BookmarksList" MaxHeight="420"
                              Background="Transparent" BorderThickness="0">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                <Setter Property="Padding" Value="0,6"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                                <GridViewRowPresenter/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Название"
                                                DisplayMemberBinding="{Binding Title}"
                                                Width="220">
                                    <GridViewColumn.HeaderContainerStyle>
                                        <Style TargetType="GridViewColumnHeader">
                                            <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="FontSize" Value="11"/>
                                        </Style>
                                    </GridViewColumn.HeaderContainerStyle>
                                </GridViewColumn>
                                <GridViewColumn Header="URL"
                                                DisplayMemberBinding="{Binding Url}"
                                                Width="380">
                                    <GridViewColumn.HeaderContainerStyle>
                                        <Style TargetType="GridViewColumnHeader">
                                            <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="FontSize" Value="11"/>
                                        </Style>
                                    </GridViewColumn.HeaderContainerStyle>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </StackPanel>

                <!-- ─── Downloads Section ─── -->
                <StackPanel x:Name="DownloadsSection" Visibility="Collapsed">
                    <TextBlock Text="Загрузки" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <TextBlock Text="Управление загруженными файлами"
                               Foreground="{StaticResource TextTertiaryBrush}" FontSize="12.5"
                               Margin="0,0,0,18"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

                    <!-- Download Folder Picker -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,16">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Папка загрузок" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                <Button Grid.Column="1" Content="📂  Открыть папку"
                                        Style="{StaticResource GlassBtn}"
                                        Padding="14,8" FontSize="12"
                                        Click="OpenDownloadFolderBtn_Click"
                                        FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="DownloadFolderInput"
                                         Style="{StaticResource SettingsTextBox}"
                                         FontSize="12"
                                         FontFamily="Consolas, 'Cascadia Code', monospace"/>
                                <Button Grid.Column="1" Content="📁  Выбрать"
                                        Style="{StaticResource GlassBtn}"
                                        Margin="10,0,0,0" Padding="14,8" FontSize="12"
                                        Click="ChooseDownloadFolderBtn_Click"
                                        FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Active Downloads -->
                    <TextBlock Text="Активные загрузки" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

                    <ListView x:Name="ActiveDownloadsList" MaxHeight="260"
                              Background="Transparent" BorderThickness="0"
                              Margin="0,0,0,16">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                <Setter Property="Padding" Value="0,4"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border Background="{StaticResource BgSurfaceBrush}"
                                                    BorderBrush="{StaticResource BorderSubtleBrush}"
                                                    BorderThickness="1" CornerRadius="10"
                                                    Padding="14" Margin="0,0,0,6">
                                                <ContentPresenter/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <!-- File name + status icon -->
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding FileName}" FontSize="13" FontWeight="Medium"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                        <TextBlock Grid.Column="1" Text="{Binding StatusIcon}" FontSize="13"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </Grid>
                                    <!-- Progress bar -->
                                    <Grid Grid.Row="1" Margin="0,6,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ProgressBar Value="{Binding Progress}" Maximum="100" Height="6"
                                                     BorderThickness="0" Background="{StaticResource BgElevatedBrush}">
                                            <ProgressBar.Template>
                                                <ControlTemplate TargetType="ProgressBar">
                                                    <Grid>
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="3"/>
                                                        <Border x:Name="PART_Track" CornerRadius="3">
                                                            <Border.Background>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                    <GradientStop Color="{StaticResource AccentDeep}" Offset="0"/>
                                                                    <GradientStop Color="{StaticResource Accent}" Offset="0.5"/>
                                                                    <GradientStop Color="{StaticResource Cyan}" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Border.Background>
                                                        </Border>
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                            <Setter TargetName="PART_Track" Property="Background">
                                                                <Setter.Value>
                                                                    <SolidColorBrush Color="{StaticResource Warning}"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </ProgressBar.Template>
                                        </ProgressBar>
                                        <TextBlock Grid.Column="1" Text="{Binding Progress, StringFormat={}{0:F0}%}"
                                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="8,0,0,0" VerticalAlignment="Center"
                                                   FontFamily="Consolas, 'Cascadia Code', monospace"/>
                                    </Grid>
                                    <!-- Speed + size + buttons -->
                                    <Grid Grid.Row="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding SpeedFormatted}" FontSize="11"
                                                       Foreground="{StaticResource AccentSoftBrush}"
                                                       FontFamily="Consolas, 'Cascadia Code', monospace"/>
                                            <TextBlock Text="  •  " FontSize="11"
                                                       Foreground="{StaticResource TextTertiaryBrush}"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding ReceivedSizeFormatted}" FontSize="11"
                                                       Foreground="{StaticResource TextTertiaryBrush}"
                                                       FontFamily="Consolas, 'Cascadia Code', monospace"/>
                                            <TextBlock Text=" / " FontSize="11"
                                                       Foreground="{StaticResource TextTertiaryBrush}"/>
                                            <TextBlock Text="{Binding TotalSizeFormatted}" FontSize="11"
                                                       Foreground="{StaticResource TextTertiaryBrush}"
                                                       FontFamily="Consolas, 'Cascadia Code', monospace"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <!-- Pause/Resume -->
                                            <Button ToolTip="Приостановить"
                                                    Width="28" Height="28" FontSize="12"
                                                    Click="PauseResumeBtn_Click"
                                                    Tag="{Binding}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource IconBtn}">
                                                        <Setter Property="Content" Value="⏸"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                                                <Setter Property="Content" Value="▶"/>
                                                                <Setter Property="ToolTip" Value="Возобновить"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <!-- Cancel -->
                                            <Button Content="✕" ToolTip="Отменить"
                                                    Style="{StaticResource IconBtn}"
                                                    Width="28" Height="28" FontSize="10"
                                                    Foreground="{StaticResource DangerBrush}"
                                                    Click="CancelDownloadBtn_Click"
                                                    Tag="{Binding}"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Completed Downloads -->
                    <TextBlock Text="История загрузок" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                    </Grid>

                    <ListView x:Name="CompletedDownloadsList" MaxHeight="320"
                              Background="Transparent" BorderThickness="0">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                <Setter Property="Padding" Value="0,4"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border Background="{StaticResource BgSurfaceBrush}"
                                                    BorderBrush="{StaticResource BorderSubtleBrush}"
                                                    BorderThickness="1" CornerRadius="10"
                                                    Padding="14" Margin="0,0,0,6">
                                                <ContentPresenter/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <!-- File name + status icon -->
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding FileName}" FontSize="13" FontWeight="Medium"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                        <TextBlock Grid.Column="1" Text="{Binding StatusIcon}" FontSize="13"
                                                   Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                            <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                                            <Setter Property="Foreground" Value="{StaticResource WarningBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                    <!-- Size + buttons -->
                                    <Grid Grid.Row="1" Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ReceivedSizeFormatted}" FontSize="11"
                                                       Foreground="{StaticResource TextTertiaryBrush}"
                                                       FontFamily="Consolas, 'Cascadia Code', monospace"/>
                                            <TextBlock Text="  •  " FontSize="11"
                                                       Foreground="{StaticResource TextTertiaryBrush}"/>
                                            <TextBlock Text="{Binding CompletedAt, StringFormat={}{0:dd.MM.yyyy HH:mm}}"
                                                       FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"
                                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <!-- Open file -->
                                            <Button Content="📄" ToolTip="Открыть файл"
                                                    Style="{StaticResource IconBtn}"
                                                    Width="28" Height="28" FontSize="12"
                                                    Click="OpenFileBtn_Click"
                                                    Tag="{Binding}"/>
                                            <!-- Open folder -->
                                            <Button Content="📂" ToolTip="Показать в папке"
                                                    Style="{StaticResource IconBtn}"
                                                    Width="28" Height="28" FontSize="12"
                                                    Click="OpenFileLocationBtn_Click"
                                                    Tag="{Binding}"/>
                                            <!-- Delete -->
                                            <Button Content="🗑" ToolTip="Удалить"
                                                    Style="{StaticResource IconBtn}"
                                                    Width="28" Height="28" FontSize="12"
                                                    Foreground="{StaticResource DangerBrush}"
                                                    Click="DeleteDownloadBtn_Click"
                                                    Tag="{Binding}"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Clear completed button -->
                    <Button Content="🗑️  Очистить завершённые"
                            Style="{StaticResource GlassBtn}"
                            Margin="0,12,0,0" Padding="16,10"
                            HorizontalAlignment="Left"
                            Click="ClearCompletedBtn_Click"
                            FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                </StackPanel>

                <!-- ─── Sync Section ─── -->
                <StackPanel x:Name="SyncSection" Visibility="Collapsed">
                    <TextBlock Text="Синхронизация закладок" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <TextBlock Text="Экспорт и импорт закладок через файл"
                               Foreground="{StaticResource TextTertiaryBrush}" FontSize="12.5"
                               Margin="0,0,0,28"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

                    <!-- Info Card -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="ℹ️" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Top"/>
                            <StackPanel>
                                <TextBlock Text="Как это работает" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                <TextBlock Text="Экспорт сохраняет все закладки в JSON-файл. Импорт добавляет закладки из файла, пропуская дубликаты."
                                           FontSize="12.5" Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" Margin="0,6,0,0" LineHeight="19"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Export Card -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="📤 Экспорт закладок" FontSize="14" FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                <TextBlock Text="Сохранить все закладки в файл"
                                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,4,0,0"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            </StackPanel>
                            <Button Grid.Column="1" x:Name="ExportBookmarksBtn"
                                    Content="Экспорт"
                                    Style="{StaticResource GlassBtn}"
                                    Padding="20,10"
                                    Click="ExportBookmarksBtn_Click"
                                    FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                        </Grid>
                    </Border>

                    <!-- Import Card -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="📥 Импорт закладок" FontSize="14" FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                <TextBlock Text="Добавить закладки из файла (дубликаты пропускаются)"
                                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,4,0,0"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            </StackPanel>
                            <Button Grid.Column="1" x:Name="ImportBookmarksBtn"
                                    Content="Импорт"
                                    Style="{StaticResource GlassBtn}"
                                    Padding="20,10"
                                    Click="ImportBookmarksBtn_Click"
                                    FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- ─── About Section ─── -->
                <StackPanel x:Name="AboutSection" Visibility="Collapsed">
                    <TextBlock Text="О программе" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="16" Padding="32" Margin="0,20,0,28">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="👻" FontSize="44" HorizontalAlignment="Center"
                                       Margin="0,0,0,14"
                                       RenderTransformOrigin="0.5,0.5">
                                <TextBlock.Effect>
                                    <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.4"
                                                      Color="{StaticResource Accent}"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock Text="KING" FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            <TextBlock Text="v1.0 — Шахматный браузер нового поколения"
                                       FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,6,0,0"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Горячие клавиши" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,14"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18">
                        <StackPanel>
                            <TextBlock Text="Ctrl+T  —  Новая вкладка" FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6"
                                       FontFamily="Consolas, 'Cascadia Code', monospace"/>
                            <TextBlock Text="Ctrl+W  —  Закрыть вкладку" FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6"
                                       FontFamily="Consolas, 'Cascadia Code', monospace"/>
                            <TextBlock Text="Ctrl+L  —  Адресная строка" FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6"
                                       FontFamily="Consolas, 'Cascadia Code', monospace"/>
                            <TextBlock Text="Ctrl+Shift+H  —  Stealth режим" FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6"
                                       FontFamily="Consolas, 'Cascadia Code', monospace"/>
                            <TextBlock Text="Alt+←/→  —  Назад/Вперёд" FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6"
                                       FontFamily="Consolas, 'Cascadia Code', monospace"/>
                            <TextBlock Text="Ctrl+R  —  Обновить" FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6"
                                       FontFamily="Consolas, 'Cascadia Code', monospace"/>
                            <TextBlock Text="Ctrl+D  —  Закладка" FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6"
                                       FontFamily="Consolas, 'Cascadia Code', monospace"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
