<UserControl x:Class="GhostBrowser.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded"
             Background="{StaticResource BgDeepestBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ LEFT SIDEBAR ═══ -->
        <Border Grid.Column="0"
                Background="{StaticResource BgDeepBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,0,1,0">
            <StackPanel Margin="0,20,0,0">
                <!-- Back Button -->
                <Button x:Name="BackBtn"
                        Margin="14,8" Padding="16,10"
                        Style="{StaticResource GlassBtn}"
                        Click="BackBtn_Click">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="←" Margin="0,0,8,0" FontSize="13"/>
                            <TextBlock Text="Назад" FontSize="13" FontWeight="Medium"/>
                        </StackPanel>
                    </Button.Content>
                </Button>

                <!-- Section Title -->
                <TextBlock Text="Меню" FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="18,14,18,16"
                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

                <!-- Nav Items -->
                <Button x:Name="NavDnsBtn" Content="🌐  DNS-сервер"
                        Style="{StaticResource MenuNavItemBtn}" Margin="8,2"
                        Click="NavDns_Click" FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                <Button x:Name="NavGeneralBtn" Content="⚙️  Общие"
                        Style="{StaticResource MenuNavItemBtn}" Margin="8,2"
                        Click="NavGeneral_Click" FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                <Button x:Name="NavPrivacyBtn" Content="🛡️  Приватность"
                        Style="{StaticResource MenuNavItemBtn}" Margin="8,2"
                        Click="NavPrivacy_Click" FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                <Button x:Name="NavStealthBtn" Content="🔒  Stealth 2.0"
                        Style="{StaticResource MenuNavItemBtn}" Margin="8,2"
                        Click="NavStealth_Click" FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                <Button x:Name="NavNetworkBtn" Content="🌍  Сеть и обход"
                        Style="{StaticResource MenuNavItemBtn}" Margin="8,2"
                        Click="NavNetwork_Click" FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                <Button x:Name="NavMaskingBtn" Content="🎭  Маскировка"
                        Style="{StaticResource MenuNavItemBtn}" Margin="8,2"
                        Click="NavMasking_Click" FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                <Button x:Name="NavSessionsBtn" Content="📑  Сессии"
                        Style="{StaticResource MenuNavItemBtn}" Margin="8,2"
                        Click="NavSessions_Click" FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                <Button x:Name="NavAppearanceBtn" Content="🎨  Внешний вид"
                        Style="{StaticResource MenuNavItemBtn}" Margin="8,2"
                        Click="NavAppearance_Click" FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                <Button x:Name="NavHistoryBtn" Content="📜  История"
                        Style="{StaticResource MenuNavItemBtn}" Margin="8,2"
                        Click="NavHistory_Click" FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                <Button x:Name="NavBookmarksBtn" Content="⭐  Закладки"
                        Style="{StaticResource MenuNavItemBtn}" Margin="8,2"
                        Click="NavBookmarks_Click" FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                <Button x:Name="NavDownloadsBtn" Content="📥  Загрузки"
                        Style="{StaticResource MenuNavItemBtn}" Margin="8,2"
                        Click="NavDownloads_Click" FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                <Button x:Name="NavAboutBtn" Content="ℹ️  О программе"
                        Style="{StaticResource MenuNavItemBtn}" Margin="8,2"
                        Click="NavAbout_Click" FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
            </StackPanel>
        </Border>

        <!-- ═══ RIGHT CONTENT ═══ -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="36,28">
            <StackPanel MaxWidth="620">

                <!-- ─── DNS Section ─── -->
                <StackPanel x:Name="DnsSection" Visibility="Visible">
                    <TextBlock Text="DNS-сервер" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <TextBlock Text="Выберите DNS-сервер для подключения"
                               Foreground="{StaticResource TextTertiaryBrush}" FontSize="12.5"
                               Margin="0,0,0,28"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

                    <!-- Toggle Card -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Использовать кастомный DNS"
                                       FontSize="14" FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            <ToggleButton x:Name="UseCustomDnsToggle"
                                          IsChecked="{Binding SettingsService.UseCustomDns}"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"/>
                        </Grid>
                    </Border>

                    <TextBlock Text="Пресеты" FontSize="11.5" FontWeight="SemiBold"
                               Foreground="{StaticResource TextTertiaryBrush}"
                               Margin="0,0,0,8"/>

                    <ComboBox x:Name="DnsPresetCombo"
                              ItemsSource="{Binding SettingsService.DnsPresetsSource}"
                              SelectedValue="{Binding SettingsService.SelectedDnsPreset, Mode=TwoWay}"
                              SelectedValuePath="Name"
                              Style="{StaticResource SettingsCombo}"
                              Margin="0,0,0,16" MaxDropDownHeight="320">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="4,6">
                                    <TextBlock Text="{Binding Name}" FontWeight="Medium"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="12.5"
                                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                    <TextBlock Text="  " Foreground="{StaticResource TextTertiaryBrush}" FontSize="11"/>
                                    <TextBlock Text="{Binding Primary}"
                                               Foreground="{StaticResource AccentSoftBrush}"
                                               FontFamily="Consolas, 'Cascadia Code', monospace"
                                               FontSize="11.5" FontWeight="Medium"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Tip Card -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="12" Padding="14" Margin="0,0,0,18">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💡" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Для обхода блокировок: Cloudflare, UncensoredDNS, Control D"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" LineHeight="18"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Адрес DNS-сервера" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="DnsInput"
                                 Text="{Binding SettingsService.CustomDns, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SettingsTextBox}"
                                 FontFamily="Consolas, 'Cascadia Code', monospace"
                                 FontSize="13"/>
                        <Button Grid.Column="1" Content="🔍  Тест"
                                Style="{StaticResource GlassBtn}"
                                Margin="10,0,0,0" Padding="16,10"
                                Click="TestDnsBtn_Click"
                                FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    </Grid>
                </StackPanel>

                <!-- ─── General Section ─── -->
                <StackPanel x:Name="GeneralSection" Visibility="Collapsed">
                    <TextBlock Text="Общие настройки" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <TextBlock Text="Основные параметры браузера"
                               Foreground="{StaticResource TextTertiaryBrush}" FontSize="12.5"
                               Margin="0,0,0,28"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Тёмная тема" FontSize="14" FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            <ToggleButton x:Name="DarkThemeToggle"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"/>
                        </Grid>
                    </Border>

                    <TextBlock Text="Размер шрифта" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="FontSizeSlider"
                                Value="{Binding SettingsService.FontSize}"
                                Minimum="10" Maximum="24" TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Style="{StaticResource SettingsSlider}"/>
                        <TextBlock Grid.Column="1" x:Name="FontSizeText"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12" FontFamily="Consolas, monospace"
                                   VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Grid>

                    <TextBlock Text="Домашняя страница" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <TextBox x:Name="HomePageInput"
                             Text="{Binding SettingsService.HomePage, UpdateSourceTrigger=LostFocus}"
                             Style="{StaticResource SettingsTextBox}"
                             Margin="0,0,0,0"/>
                </StackPanel>

                <!-- ─── Privacy Section ─── -->
                <StackPanel x:Name="PrivacySection" Visibility="Collapsed">
                    <TextBlock Text="Приватность" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <TextBlock Text="Настройки безопасности"
                               Foreground="{StaticResource TextTertiaryBrush}" FontSize="12.5"
                               Margin="0,0,0,28"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Блокировка трекеров" FontSize="14" FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            <ToggleButton x:Name="BlockTrackersToggle"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"/>
                        </Grid>
                    </Border>

                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Блокировка cookies третьих сторон" FontSize="14"
                                       FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            <ToggleButton x:Name="BlockCookiesToggle"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- ─── Network / Bypass Section ─── -->
                <StackPanel x:Name="NetworkSection" Visibility="Collapsed">
                    <TextBlock Text="🌍 Сеть и прокси" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <TextBlock Text="Ручные прокси и DNS-настройки для встроенного браузера"
                               Foreground="{StaticResource TextTertiaryBrush}" FontSize="12.5"
                               Margin="0,0,0,28"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

                    <!-- GoodbyeDPI Card -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Обход блокировок (GoodbyeDPI)" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            <TextBlock Text="Локальный обход DPI (ТСПУ) провайдеров. Требует установки и прав Администратора."
                                       Foreground="{StaticResource TextTertiaryBrush}" FontSize="12"
                                       Margin="0,4,0,12" TextWrapping="Wrap"/>
                            
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="StartGoodbyeDpiBtn" Content="▶️ Запустить"
                                        Style="{StaticResource GlassBtn}" Padding="16,10" Margin="0,0,10,0"
                                        Click="StartGoodbyeDpiBtn_Click"/>
                                <Button x:Name="StopGoodbyeDpiBtn" Content="⏹️ Остановить"
                                        Style="{StaticResource GlassBtn}" Padding="16,10"
                                        Click="StopGoodbyeDpiBtn_Click"/>
                            </StackPanel>
                            <TextBlock x:Name="GoodbyeDpiStatusText" Text="Статус: Выключен" 
                                       FontSize="12" Margin="0,10,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- DNS Servers Card -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Безопасные DNS (DoH)" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Помогает обойти подмену DNS ответов провайдером."
                                       Foreground="{StaticResource TextTertiaryBrush}" FontSize="12"
                                       Margin="0,4,0,12"/>
                            <ComboBox x:Name="DnsModeCombo"
                                      Style="{StaticResource SettingsCombo}"
                                      SelectionChanged="DnsModeCombo_SelectionChanged">
                                <ComboBoxItem Content="Системный DNS (Обычный)" Tag="none"/>
                                <ComboBoxItem Content="Cloudflare (1.1.1.1)" Tag="doh_cloudflare"/>
                                <ComboBoxItem Content="Google (8.8.8.8)" Tag="doh_google"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- VPN / Proxy Card -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="VPN / Прокси по ключу" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Введите IP:Port (SOCKS5/HTTP) для ручного проксирования."
                                       Foreground="{StaticResource TextTertiaryBrush}" FontSize="12"
                                       Margin="0,4,0,12"/>
                            
                            <TextBox x:Name="VpnKeyInput"
                                     Style="{StaticResource SettingsTextBox}"
                                     Margin="0,0,0,12"
                                     FontFamily="Consolas, 'Cascadia Code', monospace"
                                     FontSize="13"/>
                            
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="ApplyVpnKeyBtn" Content="✅ Подключить"
                                        Style="{StaticResource GlassBtn}" Padding="16,10" Margin="0,0,10,0"
                                        Click="ApplyVpnKeyBtn_Click"/>
                                <Button x:Name="DisconnectVpnBtn" Content="❌ Отключить"
                                        Style="{StaticResource GlassBtn}" Padding="16,10"
                                        Click="DisconnectVpnBtn_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>






                </StackPanel>

                <!-- ─── Masking Section ─── -->
                <StackPanel x:Name="MaskingSection" Visibility="Collapsed">
                    <TextBlock Text="🎭 Маскировка браузера" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <TextBlock Text="Притворись другим браузером для обхода блокировок"
                               Foreground="{StaticResource TextTertiaryBrush}" FontSize="12.5"
                               Margin="0,0,0,28"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

                    <!-- User-Agent Preset Selection -->
                    <TextBlock Text="Пресет User-Agent" FontSize="12" FontWeight="Medium"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,8"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <ComboBox x:Name="UserAgentPresetCombo"
                              Style="{StaticResource SettingsCombo}"
                              Margin="0,0,0,12"
                              SelectionChanged="UserAgentPresetCombo_SelectionChanged">
                        <ComboBoxItem Content="Google Chrome (Windows 11)" Tag="Chrome"/>
                        <ComboBoxItem Content="Microsoft Edge (Windows 11)" Tag="Edge"/>
                        <ComboBoxItem Content="Mozilla Firefox (Windows 11)" Tag="Firefox"/>
                        <ComboBoxItem Content="Safari (macOS)" Tag="Safari"/>
                        <ComboBoxItem Content="Chrome Mobile (Android)" Tag="ChromeMobile"/>
                        <ComboBoxItem Content="Opera (Windows 11)" Tag="Opera"/>
                        <ComboBoxItem Content="Яндекс.Браузер (Windows)" Tag="YandexBrowser"/>
                        <ComboBoxItem Content="Пользовательский" Tag="Custom"/>
                    </ComboBox>

                    <!-- Custom User-Agent Input (visible only when Custom is selected) -->
                    <Border x:Name="CustomUserAgentCard"
                            Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,16"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Пользовательский User-Agent" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,10"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            <TextBox x:Name="CustomUserAgentInput"
                                     Style="{StaticResource SettingsTextBox}"
                                     Margin="0,0,0,0"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="False"
                                     FontFamily="Consolas, 'Cascadia Code', monospace"
                                     FontSize="11"
                                     Height="60"/>
                        </StackPanel>
                    </Border>

                    <!-- Current User-Agent Display -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="12" Padding="16" Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Text="Текущий User-Agent" FontSize="12" FontWeight="Medium"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       Margin="0,0,0,8"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            <TextBlock x:Name="CurrentUserAgentDisplay"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" LineHeight="16"
                                       FontFamily="Consolas, 'Cascadia Code', monospace"
                                       Text="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/123.0.0.0 Safari/537.36"/>
                        </StackPanel>
                    </Border>

                    <!-- Apply Button -->
                    <Button x:Name="ApplyUserAgentBtn" Content="✅ Применить User-Agent"
                            Style="{StaticResource GlassBtn}"
                            Padding="16,12"
                            FontSize="13"
                            Click="ApplyUserAgentBtn_Click"
                            FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                            Margin="0,0,0,14"/>

                    <!-- Info Card -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="12" Padding="14" Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Text="💡 Как это работает" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,8"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            <TextBlock Text="• User-Agent — строка, которую браузер отправляет сайтам для идентификации"
                                       FontSize="11.5" Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" LineHeight="17"
                                       Margin="0,0,0,4"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            <TextBlock Text="• Колледж может блокировать неизвестные браузеры по User-Agent"
                                       FontSize="11.5" Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" LineHeight="17"
                                       Margin="0,0,0,4"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            <TextBlock Text="• Маскировка под Chrome/Edge позволяет обойти такие блокировки"
                                       FontSize="11.5" Foreground="{StaticResource AccentSoftBrush}"
                                       TextWrapping="Wrap" LineHeight="17"
                                       FontWeight="Medium"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            <TextBlock Text="• ⚠️ Применение требует пересоздания вкладок (URL сохраняются)"
                                       FontSize="11.5" Foreground="#FFB000"
                                       TextWrapping="Wrap" LineHeight="17"
                                       FontWeight="Medium"
                                       Margin="0,4,0,0"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ─── Sessions Section ─── -->
                <StackPanel x:Name="SessionsSection" Visibility="Collapsed">
                    <TextBlock Text="📑 Менеджер сессий" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <TextBlock Text="Сохраняйте и восстанавливайте наборы открытых вкладок"
                               Foreground="{StaticResource TextTertiaryBrush}" FontSize="12.5"
                               Margin="0,0,0,28"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

                    <!-- Save Current Session Button -->
                    <Button Content="💾  Сохранить текущую сессию"
                            Style="{StaticResource GlassBtn}"
                            Padding="16,12"
                            FontSize="13"
                            Command="{Binding SaveSessionCommand}"
                            FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                            Margin="0,0,0,14"/>

                    <!-- Sessions List -->
                    <TextBlock Text="Сохранённые сессии" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,10"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

                    <ItemsControl x:Name="SessionsList"
                                  ItemsSource="{Binding SessionService.Sessions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource BgSurfaceBrush}"
                                        BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                                        CornerRadius="10" Padding="14" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Session Info -->
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Medium"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock FontSize="11"
                                                           Foreground="{StaticResource TextTertiaryBrush}"
                                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}📅 {0}  ·  📄 {1} вкладок">
                                                            <Binding Path="CreatedAt" StringFormat="dd.MM.yyyy HH:mm"/>
                                                            <Binding Path="TabCount"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Restore Button -->
                                        <Button Grid.Column="1" Content="📂"
                                                Style="{StaticResource IconBtn}"
                                                Margin="0,0,6,0"
                                                ToolTip="Восстановить сессию"
                                                Command="{Binding DataContext.RestoreSessionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding Id}"
                                                FontSize="14"/>

                                        <!-- Delete Button -->
                                        <Button Grid.Column="2" Content="🗑️"
                                                Style="{StaticResource IconBtn}"
                                                ToolTip="Удалить сессию"
                                                Command="{Binding DataContext.DeleteSessionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding Id}"
                                                FontSize="14"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>

                    <!-- Empty State -->
                    <TextBlock x:Name="SessionsEmptyText"
                               Text="Нет сохранённых сессий"
                               FontSize="12" Foreground="{StaticResource TextTertiaryBrush}"
                               TextAlignment="Center" Margin="0,20,0,0"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

                    <!-- Info Card -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="12" Padding="14" Margin="0,18,0,0">
                        <StackPanel>
                            <TextBlock Text="💡 Как это работает" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,8"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            <TextBlock Text="• Сохраните текущие вкладки как сессию для быстрого восстановления"
                                       FontSize="11.5" Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" LineHeight="17"
                                       Margin="0,0,0,4"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            <TextBlock Text="• Можно сохранить несколько сессий для разных задач (работа, учёба, развлечения)"
                                       FontSize="11.5" Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" LineHeight="17"
                                       Margin="0,0,0,4"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            <TextBlock Text="• При восстановлении текущие вкладки закрываются и открываются сохранённые"
                                       FontSize="11.5" Foreground="{StaticResource AccentSoftBrush}"
                                       TextWrapping="Wrap" LineHeight="17"
                                       FontWeight="Medium"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ─── Appearance Section ─── -->
                <StackPanel x:Name="AppearanceSection" Visibility="Collapsed">
                    <TextBlock Text="🎨 Внешний вид" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <TextBlock Text="Настройте тему и акцентный цвет под себя"
                               Foreground="{StaticResource TextTertiaryBrush}" FontSize="12.5"
                               Margin="0,0,0,28"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

                    <!-- Theme Selection -->
                    <TextBlock Text="Тема оформления" FontSize="12" FontWeight="Medium"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,8"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Button Content="🌙  Тёмная" Padding="16,10" Margin="0,0,8,0"
                                Style="{StaticResource GlassBtn}" FontSize="12"
                                Command="{Binding ApplyThemeCommand}"
                                CommandParameter="Dark"
                                FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                        <Button Content="☀️  Светлая" Padding="16,10" Margin="0,0,8,0"
                                Style="{StaticResource GlassBtn}" FontSize="12"
                                Command="{Binding ApplyThemeCommand}"
                                CommandParameter="Light"
                                FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                        <Button Content="🖥️  Системная" Padding="16,10"
                                Style="{StaticResource GlassBtn}" FontSize="12"
                                Command="{Binding ApplyThemeCommand}"
                                CommandParameter="System"
                                FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    </StackPanel>

                    <!-- Accent Color Selection -->
                    <TextBlock Text="Акцентный цвет" FontSize="12" FontWeight="Medium"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,10"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                        <!-- Blue -->
                        <Button Width="36" Height="36" Margin="0,0,8,0"
                                Style="{StaticResource GlassBtn}" FontSize="16"
                                Content="🔵"
                                Command="{Binding ApplyThemeCommand}"
                                CommandParameter="AccentBlue"
                                ToolTip="Синий"
                                FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                        <!-- Purple -->
                        <Button Width="36" Height="36" Margin="0,0,8,0"
                                Style="{StaticResource GlassBtn}" FontSize="16"
                                Content="🟣"
                                Command="{Binding ApplyThemeCommand}"
                                CommandParameter="AccentPurple"
                                ToolTip="Фиолетовый"
                                FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                        <!-- Green -->
                        <Button Width="36" Height="36" Margin="0,0,8,0"
                                Style="{StaticResource GlassBtn}" FontSize="16"
                                Content="🟢"
                                Command="{Binding ApplyThemeCommand}"
                                CommandParameter="AccentGreen"
                                ToolTip="Зелёный"
                                FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                        <!-- Red -->
                        <Button Width="36" Height="36" Margin="0,0,8,0"
                                Style="{StaticResource GlassBtn}" FontSize="16"
                                Content="🔴"
                                Command="{Binding ApplyThemeCommand}"
                                CommandParameter="AccentRed"
                                ToolTip="Красный"
                                FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                        <!-- Orange -->
                        <Button Width="36" Height="36" Margin="0,0,8,0"
                                Style="{StaticResource GlassBtn}" FontSize="16"
                                Content="🟠"
                                Command="{Binding ApplyThemeCommand}"
                                CommandParameter="AccentOrange"
                                ToolTip="Оранжевый"
                                FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                        <!-- Cyan -->
                        <Button Width="36" Height="36"
                                Style="{StaticResource GlassBtn}" FontSize="16"
                                Content="🔷"
                                Command="{Binding ApplyThemeCommand}"
                                CommandParameter="AccentCyan"
                                ToolTip="Голубой"
                                FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    </StackPanel>

                    <!-- Info Card -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="12" Padding="14">
                        <StackPanel>
                            <TextBlock Text="💡 Примечание" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,8"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            <TextBlock Text="• Светлая тема и кастомные акцентные цвета будут полностью реализованы в следующем обновлении"
                                       FontSize="11.5" Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" LineHeight="17"
                                       Margin="0,0,0,4"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            <TextBlock Text="• Сейчас тема сохраняется в настройках и будет применяться автоматически"
                                       FontSize="11.5" Foreground="{StaticResource AccentSoftBrush}"
                                       TextWrapping="Wrap" LineHeight="17"
                                       FontWeight="Medium"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ─── Stealth 2.0 Section ─── -->
                <StackPanel x:Name="StealthSection" Visibility="Collapsed">
                    <TextBlock Text="🔒 Stealth 2.0" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <TextBlock Text="Полная невидимость и защита от скриншотов"
                               Foreground="{StaticResource TextTertiaryBrush}" FontSize="12.5"
                               Margin="0,0,0,28"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

                    <!-- Auto-Enable Stealth -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Авто-включение Stealth" FontSize="14" FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                <TextBlock Text="Включать защиту при запуске" FontSize="11"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           Margin="0,2,0,0"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            </StackPanel>
                            <ToggleButton x:Name="AutoStealthToggle"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"
                                          Checked="AutoStealthToggle_Changed"
                                          Unchecked="AutoStealthToggle_Changed"/>
                        </Grid>
                    </Border>

                    <!-- Block PrintScreen -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Блокировка PrintScreen" FontSize="14" FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                <TextBlock Text="Перехват PrintScreen, Ctrl+PrintScreen, Alt+PrintScreen" FontSize="11"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           Margin="0,2,0,0"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            </StackPanel>
                            <ToggleButton x:Name="BlockPrintScreenToggle"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"
                                          Checked="BlockPrintScreenToggle_Changed"
                                          Unchecked="BlockPrintScreenToggle_Changed"/>
                        </Grid>
                    </Border>

                    <!-- Block Snipping Tool -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Блокировка Snipping Tool" FontSize="14" FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                <TextBlock Text="Защита от скриншотов через PrintWindow API" FontSize="11"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           Margin="0,2,0,0"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            </StackPanel>
                            <ToggleButton x:Name="BlockSnippingToolToggle"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"
                                          Checked="BlockSnippingToolToggle_Changed"
                                          Unchecked="BlockSnippingToolToggle_Changed"/>
                        </Grid>
                    </Border>

                    <!-- Anti-Fingerprint -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Анти-Fingerprint" FontSize="14" FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                <TextBlock Text="Блокировка Canvas, WebGL, Screencast API" FontSize="11"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           Margin="0,2,0,0"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            </StackPanel>
                            <ToggleButton x:Name="AntiFingerprintToggle"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"
                                          Checked="AntiFingerprintToggle_Changed"
                                          Unchecked="AntiFingerprintToggle_Changed"/>
                        </Grid>
                    </Border>

                    <!-- Panic Key (F12) -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Паник-кнопка (F12)" FontSize="14" FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                <TextBlock Text="F12 → свернуть, открыть Google, очистить данные" FontSize="11"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           Margin="0,2,0,0"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            </StackPanel>
                            <ToggleButton x:Name="EnablePanicKeyToggle"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"
                                          Checked="EnablePanicKeyToggle_Changed"
                                          Unchecked="EnablePanicKeyToggle_Changed"/>
                        </Grid>
                    </Border>

                    <!-- Status Card -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource SuccessBrush}" BorderThickness="2"
                            CornerRadius="14" Padding="18" Margin="0,16,0,0">
                        <StackPanel>
                            <TextBlock Text="✅ Статус защиты" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            <TextBlock x:Name="StealthStatusText" Text="Все защиты активны" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ─── History Section ─── -->
                <StackPanel x:Name="HistorySection" Visibility="Collapsed">
                    <TextBlock Text="История" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <TextBlock Text="Последние посещённые страницы"
                               Foreground="{StaticResource TextTertiaryBrush}" FontSize="12.5"
                               Margin="0,0,0,18"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <Button x:Name="ClearHistoryBtn" Content="🗑️  Очистить историю"
                            Style="{StaticResource GlassBtn}"
                            Margin="0,0,0,18" Padding="16,10"
                            HorizontalAlignment="Left"
                            Click="ClearHistoryBtn_Click"
                            FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

                    <ListView x:Name="HistoryList" MaxHeight="420"
                              Background="Transparent" BorderThickness="0">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                <Setter Property="Padding" Value="0,6"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                                <GridViewRowPresenter/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Заголовок"
                                                DisplayMemberBinding="{Binding Title}"
                                                Width="220">
                                    <GridViewColumn.HeaderContainerStyle>
                                        <Style TargetType="GridViewColumnHeader">
                                            <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="FontSize" Value="11"/>
                                        </Style>
                                    </GridViewColumn.HeaderContainerStyle>
                                </GridViewColumn>
                                <GridViewColumn Header="URL"
                                                DisplayMemberBinding="{Binding Url}"
                                                Width="260">
                                    <GridViewColumn.HeaderContainerStyle>
                                        <Style TargetType="GridViewColumnHeader">
                                            <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="FontSize" Value="11"/>
                                        </Style>
                                    </GridViewColumn.HeaderContainerStyle>
                                </GridViewColumn>
                                <GridViewColumn Header="Дата"
                                                DisplayMemberBinding="{Binding VisitedAt}"
                                                Width="140">
                                    <GridViewColumn.HeaderContainerStyle>
                                        <Style TargetType="GridViewColumnHeader">
                                            <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="FontSize" Value="11"/>
                                        </Style>
                                    </GridViewColumn.HeaderContainerStyle>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </StackPanel>

                <!-- ─── Bookmarks Section ─── -->
                <StackPanel x:Name="BookmarksSection" Visibility="Collapsed">
                    <TextBlock Text="Закладки" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <TextBlock Text="Сохранённые страницы"
                               Foreground="{StaticResource TextTertiaryBrush}" FontSize="12.5"
                               Margin="0,0,0,18"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <ListView x:Name="BookmarksList" MaxHeight="420"
                              Background="Transparent" BorderThickness="0">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                <Setter Property="Padding" Value="0,6"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                                <GridViewRowPresenter/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Название"
                                                DisplayMemberBinding="{Binding Title}"
                                                Width="220">
                                    <GridViewColumn.HeaderContainerStyle>
                                        <Style TargetType="GridViewColumnHeader">
                                            <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="FontSize" Value="11"/>
                                        </Style>
                                    </GridViewColumn.HeaderContainerStyle>
                                </GridViewColumn>
                                <GridViewColumn Header="URL"
                                                DisplayMemberBinding="{Binding Url}"
                                                Width="380">
                                    <GridViewColumn.HeaderContainerStyle>
                                        <Style TargetType="GridViewColumnHeader">
                                            <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="FontSize" Value="11"/>
                                        </Style>
                                    </GridViewColumn.HeaderContainerStyle>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </StackPanel>

                <!-- ─── Downloads Section ─── -->
                <StackPanel x:Name="DownloadsSection" Visibility="Collapsed">
                    <TextBlock Text="Загрузки" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <TextBlock Text="Управление загруженными файлами"
                               Foreground="{StaticResource TextTertiaryBrush}" FontSize="12.5"
                               Margin="0,0,0,18"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

                    <!-- Download Folder Picker -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,16">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Папка загрузок" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                <Button Grid.Column="1" Content="📂  Открыть папку"
                                        Style="{StaticResource GlassBtn}"
                                        Padding="14,8" FontSize="12"
                                        Click="OpenDownloadFolderBtn_Click"
                                        FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="DownloadFolderInput"
                                         Style="{StaticResource SettingsTextBox}"
                                         FontSize="12"
                                         FontFamily="Consolas, 'Cascadia Code', monospace"/>
                                <Button Grid.Column="1" Content="📁  Выбрать"
                                        Style="{StaticResource GlassBtn}"
                                        Margin="10,0,0,0" Padding="14,8" FontSize="12"
                                        Click="ChooseDownloadFolderBtn_Click"
                                        FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Active Downloads -->
                    <TextBlock Text="Активные загрузки" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

                    <ListView x:Name="ActiveDownloadsList" MaxHeight="260"
                              Background="Transparent" BorderThickness="0"
                              Margin="0,0,0,16">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                <Setter Property="Padding" Value="0,4"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border Background="{StaticResource BgSurfaceBrush}"
                                                    BorderBrush="{StaticResource BorderSubtleBrush}"
                                                    BorderThickness="1" CornerRadius="10"
                                                    Padding="14" Margin="0,0,0,6">
                                                <ContentPresenter/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <!-- File name + status icon -->
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding FileName}" FontSize="13" FontWeight="Medium"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                        <TextBlock Grid.Column="1" Text="{Binding StatusIcon}" FontSize="13"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </Grid>
                                    <!-- Progress bar -->
                                    <Grid Grid.Row="1" Margin="0,6,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ProgressBar Value="{Binding Progress}" Maximum="100" Height="6"
                                                     BorderThickness="0" Background="{StaticResource BgElevatedBrush}">
                                            <ProgressBar.Template>
                                                <ControlTemplate TargetType="ProgressBar">
                                                    <Grid>
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="3"/>
                                                        <Border x:Name="PART_Track" CornerRadius="3">
                                                            <Border.Background>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                    <GradientStop Color="{StaticResource AccentDeep}" Offset="0"/>
                                                                    <GradientStop Color="{StaticResource Accent}" Offset="0.5"/>
                                                                    <GradientStop Color="{StaticResource Cyan}" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Border.Background>
                                                        </Border>
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                            <Setter TargetName="PART_Track" Property="Background">
                                                                <Setter.Value>
                                                                    <SolidColorBrush Color="{StaticResource Warning}"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </ProgressBar.Template>
                                        </ProgressBar>
                                        <TextBlock Grid.Column="1" Text="{Binding Progress, StringFormat={}{0:F0}%}"
                                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="8,0,0,0" VerticalAlignment="Center"
                                                   FontFamily="Consolas, 'Cascadia Code', monospace"/>
