                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                </StackPanel>
                            </Border>
                            <Border Background="{StaticResource BgDeepestBrush}" CornerRadius="8"
                                    Padding="10,8" Margin="0,0,6,6" MinWidth="180">
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="#1e1e2e" CornerRadius="5"
                                            Padding="6,3" Margin="0,0,8,0">
                                        <TextBlock Text="Ctrl+⇧+N" FontSize="10" FontWeight="Bold"
                                                   Foreground="White"
                                                   FontFamily="Consolas, monospace"/>
                                    </Border>
                                    <TextBlock Text="Окно инкогнито" FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                </StackPanel>
                            </Border>
                            <Border Background="{StaticResource BgDeepestBrush}" CornerRadius="8"
                                    Padding="10,8" Margin="0,0,6,6" MinWidth="180">
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="#1e1e2e" CornerRadius="5"
                                            Padding="6,3" Margin="0,0,8,0">
                                        <TextBlock Text="Ctrl+⇧+P" FontSize="10" FontWeight="Bold"
                                                   Foreground="White"
                                                   FontFamily="Consolas, monospace"/>
                                    </Border>
                                    <TextBlock Text="Скриншот" FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                </StackPanel>
                            </Border>
                            <Border Background="{StaticResource BgDeepestBrush}" CornerRadius="8"
                                    Padding="10,8" Margin="0,0,6,6" MinWidth="180">
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="#1e1e2e" CornerRadius="5"
                                            Padding="6,3" Margin="0,0,8,0">
                                        <TextBlock Text="Ctrl+⇧+S" FontSize="10" FontWeight="Bold"
                                                   Foreground="White"
                                                   FontFamily="Consolas, monospace"/>
                                    </Border>
                                    <TextBlock Text="Блок. PrintScreen" FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                </StackPanel>
                            </Border>
                            <Border Background="{StaticResource BgDeepestBrush}" CornerRadius="8"
                                    Padding="10,8" Margin="0,0,6,6" MinWidth="180">
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="#1e1e2e" CornerRadius="5"
                                            Padding="6,3" Margin="0,0,8,0">
                                        <TextBlock Text="Alt+←/→" FontSize="10" FontWeight="Bold"
                                                   Foreground="White"
                                                   FontFamily="Consolas, monospace"/>
                                    </Border>
                                    <TextBlock Text="Назад/Вперёд" FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                    </Border>

                    <!-- Tech + Footer -->
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                            CornerRadius="14" Padding="18" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Технологии" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,8"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
