                                                    Foreground="{StaticResource DangerBrush}"
                                                    Click="CancelDownloadBtn_Click"
                                                    Tag="{Binding}"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
