                                       FontSize="11.5" Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" LineHeight="17"
                                       FontFamily="Consolas, 'Cascadia Code', monospace"/>
                            <Border BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,1,0,0"
                                    Margin="0,14,0,14"/>
                            <TextBlock Text="© 2026 KingBrowser  •  MIT License"
                                       FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"
                                       HorizontalAlignment="Center"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
