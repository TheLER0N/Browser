<UserControl x:Class="GhostBrowser.Views.SidebarPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgDeepBrush}"
             BorderBrush="{StaticResource BorderSubtleBrush}"
             BorderThickness="1,0,0,0">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header with close button -->
        <Border Grid.Row="0" Padding="12,10"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Tab buttons -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="TabBookmarksBtn" Content="⭐ Закладки"
                            Style="{StaticResource GlassBtn}" Padding="10,6" Margin="0,0,4,0"
                            FontSize="11" Click="TabBookmarks_Click"
                            FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <Button x:Name="TabHistoryBtn" Content="📜 История"
                            Style="{StaticResource GlassBtn}" Padding="10,6" Margin="0,0,4,0"
                            FontSize="11" Click="TabHistory_Click"
                            FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <Button x:Name="TabDownloadsBtn" Content="📥 Загрузки"
                            Style="{StaticResource GlassBtn}" Padding="10,6"
                            FontSize="11" Click="TabDownloads_Click"
                            FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                </StackPanel>

                <!-- Close button -->
                <Button Grid.Column="1" Content="✕" Width="28" Height="28"
                        Style="{StaticResource IconBtn}" FontSize="11"
                        Click="CloseBtn_Click" ToolTip="Закрыть панель"/>
            </Grid>
        </Border>

        <!-- Content area -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8">
            <Grid>
                <!-- Bookmarks Tab -->
                <StackPanel x:Name="BookmarksTab" Visibility="Visible">
                <ItemsControl x:Name="BookmarksList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Title}"
                                    Style="{StaticResource GlassBtn}"
                                    Margin="0,0,0,4" Padding="10,6"
                                    FontSize="11" HorizontalContentAlignment="Left"
                                    Cursor="Hand"
                                    Command="{Binding DataContext.NavigateToBookmarkCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding Url}"
                                    FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock x:Name="BookmarksEmptyText"
                           Text="Нет закладок"
                           FontSize="12" Foreground="{StaticResource TextTertiaryBrush}"
                           TextAlignment="Center" Margin="0,20,0,0"
                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
            </StackPanel>

            <!-- History Tab -->
            <StackPanel x:Name="HistoryTab" Visibility="Collapsed">
                <ItemsControl x:Name="HistoryList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource BgSurfaceBrush}"
                                    BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                                    CornerRadius="8" Padding="10" Margin="0,0,0,4">
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="Medium"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                    <TextBlock Text="{Binding Url}" FontSize="10"
                                               Foreground="{StaticResource TextTertiaryBrush}"
                                               TextTrimming="CharacterEllipsis" Margin="0,2,0,0"
                                               FontFamily="Consolas, monospace"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock x:Name="HistoryEmptyText"
                           Text="Нет истории"
                           FontSize="12" Foreground="{StaticResource TextTertiaryBrush}"
                           TextAlignment="Center" Margin="0,20,0,0"
                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
            </StackPanel>

            <!-- Downloads Tab -->
            <StackPanel x:Name="DownloadsTab" Visibility="Collapsed">
                <ItemsControl x:Name="DownloadsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource BgSurfaceBrush}"
                                    BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                                    CornerRadius="8" Padding="10" Margin="0,0,0,4">
                                <StackPanel>
                                    <TextBlock Text="{Binding FileName}" FontSize="12" FontWeight="Medium"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                    <TextBlock Text="{Binding StatusText}" FontSize="10"
                                               Foreground="{StaticResource TextTertiaryBrush}"
                                               Margin="0,2,0,0"
                                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                    <ProgressBar Height="3" Margin="0,4,0,0"
                                                 Maximum="100" Value="{Binding Progress}"
                                                 Background="{StaticResource BgDeepestBrush}">
                                        <ProgressBar.Foreground>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="{StaticResource AccentDeep}" Offset="0"/>
                                                <GradientStop Color="{StaticResource Accent}" Offset="1"/>
                                            </LinearGradientBrush>
                                        </ProgressBar.Foreground>
                                    </ProgressBar>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock x:Name="DownloadsEmptyText"
                           Text="Нет загрузок"
                           FontSize="12" Foreground="{StaticResource TextTertiaryBrush}"
                           TextAlignment="Center" Margin="0,20,0,0"
                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
            </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
