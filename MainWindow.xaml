<Window x:Class="GhostBrowser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:GhostBrowser"
        xmlns:vm="clr-namespace:GhostBrowser.ViewModels"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Google Chrome"
        Height="720" Width="1280"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        MinWidth="860" MinHeight="520"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        SizeChanged="Window_SizeChanged"
        ShowInTaskbar="False">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="8" GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Storyboard x:Key="WindowFadeIn">
            <DoubleAnimation Storyboard.TargetName="WindowRoot"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <PowerEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <DataTemplate DataType="{x:Type vm:TabViewModel}">
            <ContentControl Content="{Binding WebView}" />
        </DataTemplate>
    </Window.Resources>

    <!-- Outer glow -->
    <Border x:Name="WindowRoot" Opacity="0"
            SnapsToDevicePixels="True"
            UseLayoutRounding="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="0" Opacity="0.45" Color="#000000"/>
        </Border.Effect>

        <Border Background="{StaticResource BgDeepestBrush}"
                SnapsToDevicePixels="True"
                UseLayoutRounding="True"
                CornerRadius="14"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.25" Color="#000000"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="3"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="28"/>
                </Grid.RowDefinitions>

                <!-- ════════════ TITLE BAR ════════════ -->
                <Border Grid.Row="0" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1"
                        CornerRadius="14,14,0,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="{StaticResource BgDeepest}" Offset="0"/>
                            <GradientStop Color="{StaticResource BgDeep}" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Logo -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="12,0,0,0">
                            <Image x:Name="LogoImage" Width="28" Height="28"
                                   VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                            <TextBlock Text="KING" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" Margin="8,0,0,1"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                        </StackPanel>

                        <!-- Stealth Indicator -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                            <Border x:Name="StealthIndicatorBorder"
                                    Width="8" Height="8" CornerRadius="4"
                                    Background="{StaticResource TextTertiaryBrush}"
                                    VerticalAlignment="Center" Margin="0,0,8,0">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="6" ShadowDepth="0" Opacity="0.3" Color="{StaticResource TextTertiary}"/>
                                </Border.Effect>
                            </Border>
                            <TextBlock x:Name="StealthStatusText" Text="Stealth OFF"
                                       FontSize="11" FontWeight="Medium"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                        </StackPanel>

                        <!-- Window Controls -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Button x:Name="BtnMinimize" Width="46" Height="34"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    FontSize="12" Cursor="Hand" Click="BtnMinimize_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bg" Background="Transparent" CornerRadius="6">
                                                        <TextBlock Text="─" Foreground="{TemplateBinding Foreground}"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                   FontSize="13" FontFamily="Consolas"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource BgSurfaceBrush}"/>
                                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button x:Name="BtnMaximize" Width="46" Height="34"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    FontSize="11" Cursor="Hand" Click="BtnMaximize_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bg" Background="Transparent" CornerRadius="6">
                                                        <TextBlock Text="□" Foreground="{TemplateBinding Foreground}"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                   FontSize="12" FontFamily="Consolas"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource BgSurfaceBrush}"/>
                                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button x:Name="BtnClose" Width="46" Height="34"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    FontSize="10" Cursor="Hand" Click="BtnClose_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bg" Background="Transparent" CornerRadius="6">
                                                        <TextBlock Text="✕" Foreground="{TemplateBinding Foreground}"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                   FontSize="11" FontFamily="Consolas"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource DangerBrush}"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ════════════ TAB BAR ════════════ -->
                <Border Grid.Row="1" Padding="12,8,12,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="{StaticResource BgDeepest}" Offset="0"/>
                            <GradientStop Color="{StaticResource BgDeep}" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TabControl x:Name="TabsControl"
                                    Grid.Column="0"
                                    ItemsSource="{Binding Tabs}"
                                    SelectedItem="{Binding SelectedTab}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Style="{StaticResource BrowserTabControl}">
                            <TabControl.ItemContainerStyle>
                                <Style TargetType="TabItem" BasedOn="{StaticResource BrowserTabItemStyle}">
                                    <Setter Property="Header" Value="{Binding Title}"/>
                                </Style>
                            </TabControl.ItemContainerStyle>
                        </TabControl>

                        <Button Grid.Column="1" Content="+" Width="32" Height="30"
                                FontSize="18" FontWeight="Light"
                                Cursor="Hand" Margin="6,0,0,2"
                                Command="{Binding AddTabCommand}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bg" Property="Background" Value="{StaticResource BgSurfaceBrush}"/>
                                                        <Setter Property="Foreground" Value="{StaticResource AccentSoftBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <!-- ════════════ NAVIGATION BAR ════════════ -->
                <Border Grid.Row="2" Padding="14,8"
                        BorderBrush="{StaticResource BorderSubtleBrush}"
                        BorderThickness="0,0,0,1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="{StaticResource BgDeep}" Offset="0"/>
                            <GradientStop Color="{StaticResource BgPrimary}" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Content="←" Style="{StaticResource IconBtn}"
                                Margin="0,0,2,0" Command="{Binding GoBackCommand}"
                                x:Name="BtnBack" ToolTip="Назад (Alt+←)"/>

                        <Button Grid.Column="1" Content="→" Style="{StaticResource IconBtn}"
                                Margin="0,0,2,0" Command="{Binding GoForwardCommand}"
                                x:Name="BtnForward" ToolTip="Вперёд (Alt+→)"/>

                        <Button Grid.Column="2" Content="⟳" Style="{StaticResource IconBtn}"
                                Margin="0,0,2,0" Command="{Binding RefreshCommand}"
                                x:Name="BtnRefresh" ToolTip="Обновить (Ctrl+R)"/>

                        <Button Grid.Column="3" Content="⌂" Style="{StaticResource IconBtn}"
                                Margin="0,0,10,0" Command="{Binding GoHomeCommand}"
                                ToolTip="Домой"/>

                        <!-- URL Bar -->
                        <Grid Grid.Column="4">
                            <TextBox x:Name="UrlBox" Style="{StaticResource UrlBar}"
                                     Text="{Binding UrlInput, UpdateSourceTrigger=PropertyChanged}"
                                     KeyDown="UrlBox_KeyDown" GotFocus="UrlBox_GotFocus"/>
                            <TextBlock x:Name="UrlPlaceholder"
                                       Text="  Введите URL или поисковый запрос..."
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       FontSize="13.5" FontStyle="Italic"
                                       VerticalAlignment="Center" IsHitTestVisible="False"
                                       Opacity="0.7"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                        </Grid>

                        <!-- Bookmark -->
                        <Button Grid.Column="5" Margin="6,0,0,0"
                                Command="{Binding ToggleBookmarkCommand}"
                                x:Name="BtnBookmark" ToolTip="Закладка (Ctrl+D)">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource IconBtn}">
                                    <Setter Property="Content" Value="☆"/>
                                    <Setter Property="FontSize" Value="16"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBookmarked}" Value="True">
                                            <Setter Property="Content" Value="★"/>
                                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Search Engine -->
                        <Button Grid.Column="6" Margin="6,0,0,0"
                                Command="{Binding CycleSearchEngineCommand}"
                                x:Name="BtnSearchEngine" ToolTip="Поисковая система">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource IconBtn}">
                                    <Setter Property="Content" Value="{Binding SearchEngineIcon}"/>
                                    <Setter Property="FontSize" Value="14"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Stealth -->
                        <Button Grid.Column="7" Content="🕶️" Style="{StaticResource IconBtn}"
                                Margin="6,0,0,0" Command="{Binding ToggleStealthCommand}"
                                x:Name="BtnStealth" FontSize="15"
                                ToolTip="Скрыть от OBS/Discord (Ctrl+Shift+H)"/>

                        <!-- Incognito -->
                        <Button Grid.Column="8" Content="♛" Style="{StaticResource IconBtn}"
                                Margin="6,0,0,0" Click="BtnIncognito_Click"
                                x:Name="BtnIncognito" FontSize="15"
                                ToolTip="Открыть инкогнито (Ctrl+Shift+N)"/>

                        <!-- Menu -->
                        <Button Grid.Column="9" Content="⋮" Style="{StaticResource IconBtn}"
                                Margin="6,0,0,0" Click="BtnMenu_Click" x:Name="BtnMenu"
                                FontSize="18" ToolTip="Меню"/>
                    </Grid>
                </Border>

                <!-- ════════════ BOOKMARKS BAR ════════════ -->
                <Border Grid.Row="3" Padding="14,6"
                        BorderBrush="{StaticResource BorderSubtleBrush}"
                        BorderThickness="0,0,0,1">
                    <Border.Background>
                        <SolidColorBrush Color="{StaticResource BgDeepest}" Opacity="0.85"/>
                    </Border.Background>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  PanningMode="HorizontalOnly">
                        <ItemsControl x:Name="BookmarksBar"
                                      ItemsSource="{Binding BookmarkService.Bookmarks}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding Title}"
                                            Style="{StaticResource GlassBtn}"
                                            Margin="0,0,4,0"
                                            FontSize="11"
                                            Padding="10,4"
                                            Cursor="Hand"
                                            Command="{Binding DataContext.NavigateToBookmarkCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding Url}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- ════════════ PROGRESS BAR ════════════ -->
                <Border Grid.Row="4">
                    <ProgressBar x:Name="ProgressBar" Height="3"
                                 Background="Transparent" BorderThickness="0"
                                 Maximum="100" Value="0">
                        <ProgressBar.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="{StaticResource AccentDeep}" Offset="0"/>
                                <GradientStop Color="{StaticResource Accent}" Offset="0.4"/>
                                <GradientStop Color="{StaticResource AccentSoft}" Offset="1"/>
                            </LinearGradientBrush>
                        </ProgressBar.Foreground>
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ProgressBar">
                                            <Grid>
                                                <Border Background="{TemplateBinding Background}"/>
                                                <Border x:Name="PART_Track"/>
                                                <Decorator x:Name="PART_Indicator" HorizontalAlignment="Left">
                                                    <Border>
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                <GradientStop Color="{StaticResource AccentDeep}" Offset="0"/>
                                                                <GradientStop Color="{StaticResource Accent}" Offset="0.4"/>
                                                                <GradientStop Color="{StaticResource AccentSoft}" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                        <Border.Effect>
                                                            <DropShadowEffect BlurRadius="8" ShadowDepth="0"
                                                                              Opacity="0.7" Color="{StaticResource Accent}"/>
                                                        </Border.Effect>
                                                    </Border>
                                                </Decorator>
                                            </Grid>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>
                </Border>

                <!-- ════════════ CONTENT AREA ════════════ -->
                <ContentControl Grid.Row="5" x:Name="ContentArea"
                                Content="{Binding DisplayedContent}">
                    <ContentControl.Style>
                        <Style TargetType="ContentControl">
                            <Setter Property="Background" Value="{StaticResource BgDeepestBrush}"/>
                        </Style>
                    </ContentControl.Style>
                </ContentControl>

                <!-- ════════════ STATUS BAR ════════════ -->
                <Border Grid.Row="6"
                        BorderBrush="{StaticResource BorderSubtleBrush}"
                        BorderThickness="0,1,0,0"
                        CornerRadius="0,0,14,14">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="{StaticResource BgDeepest}" Offset="0"/>
                            <GradientStop Color="{StaticResource BgDeep}" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="StatusText" Grid.Column="0" Text="Готово"
                                   Foreground="{StaticResource TextTertiaryBrush}"
                                   FontSize="11" FontWeight="Light"
                                   VerticalAlignment="Center" Margin="14,0"
                                   FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Border Background="{StaticResource BgSurfaceBrush}"
                                    CornerRadius="5" Padding="6,2" Margin="0,0,6,0"
                                    VerticalAlignment="Center">
                                <TextBlock x:Name="ZoomText" Text="100%"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="10.5" FontWeight="Medium"
                                           VerticalAlignment="Center"
                                           FontFamily="Consolas, 'Cascadia Code', monospace"/>
                            </Border>

                            <TextBlock Text="·" Foreground="{StaticResource BorderSubtleBrush}"
                                       FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>

                            <Border Background="{StaticResource BgSurfaceBrush}"
                                    CornerRadius="5" Padding="8,2" Margin="0,0,10,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding ClockTime}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="10.5" FontWeight="Medium"
                                           VerticalAlignment="Center"
                                           FontFamily="Consolas, 'Cascadia Code', monospace"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

            </Grid>
        </Border>
    </Border>

    <Window.InputBindings>
        <KeyBinding Key="W" Modifiers="Control" Command="{Binding CloseTabCommand}"/>
        <KeyBinding Key="T" Modifiers="Control" Command="{Binding AddTabCommand}"/>
        <KeyBinding Key="H" Modifiers="Control+Shift" Command="{Binding ToggleStealthCommand}"/>
        <KeyBinding Key="L" Modifiers="Control" Command="{Binding FocusUrlCommand}"/>
        <KeyBinding Key="Left" Modifiers="Alt" Command="{Binding GoBackCommand}"/>
        <KeyBinding Key="Right" Modifiers="Alt" Command="{Binding GoForwardCommand}"/>
        <KeyBinding Key="R" Modifiers="Control" Command="{Binding RefreshCommand}"/>
        <KeyBinding Key="D" Modifiers="Control" Command="{Binding ToggleBookmarkCommand}"/>
    </Window.InputBindings>
</Window>
